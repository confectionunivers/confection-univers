---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import BlogSidebar from '../../components/BlogSidebar.astro';
import CommentForm from '../../components/CommentForm.astro';
import { getPostBySlug, BLOG_POSTS } from '../../lib/blog-data';

const { slug } = Astro.params;

if (!slug) {
	return Astro.redirect('/404');
}

const post = getPostBySlug(slug);

if (!post) {
	return Astro.redirect('/404');
}
---

<Layout title={`${post.title} - Confection Univers`}>
	<main class="relative">
		<Navbar />
		
		<!-- Article Hero -->
		<section class="relative overflow-hidden py-16 md:py-24" style="background: linear-gradient(135deg, #00001C 0%, #00002a 100%);">
			<!-- Background Glow -->
			<div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
				<div class="absolute left-[10%] top-[20%] w-[500px] h-[500px] rounded-full" style="background: radial-gradient(ellipse, rgba(245, 181, 68, 0.08) 0%, transparent 70%); filter: blur(120px);"></div>
			</div>

			<div class="mx-auto max-w-7xl px-6 md:px-10">
				<!-- Category -->
				<div class="mb-4 inline-block rounded-full px-4 py-2 text-xs font-bold uppercase tracking-wider" style="background: rgba(245, 181, 68, 0.9); color: #00001C;">
					{post.category}
				</div>

				<!-- Title -->
				<h1 class="hero-title font-display text-3xl font-bold uppercase tracking-tight text-white md:text-4xl lg:text-5xl">
					{post.title}
				</h1>

				<!-- Meta -->
				<div class="mt-6 flex flex-wrap items-center gap-6 text-sm font-semibold uppercase tracking-wider" style="color: #A0ACC6;">
					<div class="flex items-center gap-2">
						<svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
						</svg>
						<span>{post.date}</span>
					</div>
					<div class="flex items-center gap-2">
						<svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
						</svg>
						<span>{post.author}</span>
					</div>
				</div>
			</div>
		</section>

		<!-- Main Content -->
		<section class="py-16 md:py-24" style="background: #00001C;">
			<div class="mx-auto max-w-7xl px-6 md:px-10">
				<div class="grid gap-10 lg:grid-cols-12">
					<!-- Main Content (70%) -->
					<div class="lg:col-span-8">
						<!-- Featured Image -->
						<div class="mb-8 overflow-hidden rounded-2xl shadow-2xl" style="border: 1px solid rgba(255, 255, 255, 0.1);">
							<img
								src={post.image}
								alt={post.title}
								class="h-full w-full object-cover"
							/>
						</div>

						<!-- Article Content -->
						<article class="prose prose-invert max-w-none">
							<div class="rounded-2xl p-8 md:p-12" style="background: #00002a; border: 1px solid rgba(255, 255, 255, 0.1);">
								<div set:html={post.content} class="article-content" />
							</div>
						</article>

						<!-- CTA Block -->
						<div class="mt-12 rounded-2xl p-8 shadow-2xl transition-all duration-300 hover:-translate-y-2 hover:shadow-[#F5B544]/20" style="background: linear-gradient(135deg, #00002a 0%, #0E172A 100%); border: 2px solid rgba(245, 181, 68, 0.3);">
							<div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl" style="background: rgba(245, 181, 68, 0.1);">
								<svg class="h-6 w-6" style="color: #F5B544;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
								</svg>
							</div>
							<h3 class="mb-3 font-display text-xl font-bold uppercase tracking-tight text-white">Un projet de confection pour votre institution ?</h3>
							<p class="mb-6 text-sm leading-relaxed" style="color: #A0ACC6;">
								Cet article vous a intéressé ? Contactez Confection Univers pour discuter de votre projet de tenues professionnelles.
							</p>
							<a href="/contact" class="btn-hero-primary inline-flex justify-center">
								<span>Demander un devis</span>
								<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
								</svg>
							</a>
						</div>

						<!-- Comment Form -->
						<div class="mt-12">
							<CommentForm />
						</div>
					</div>

					<!-- Sidebar (30%) -->
					<div class="lg:col-span-4">
						<BlogSidebar />
					</div>
				</div>
			</div>
		</section>

		<Footer />
	</main>
</Layout>

<style>
	.hero-title {
		text-shadow: 0 4px 20px rgba(245, 181, 68, 0.3);
	}

	.article-content {
		color: #F8FAFC;
		line-height: 1.8;
		font-size: 1.125rem;
	}

	.article-content h2 {
		color: #F5B544;
		font-size: 1.75rem;
		font-weight: 700;
		margin-top: 2.5rem;
		margin-bottom: 1rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.article-content p {
		margin-bottom: 1.5rem;
		color: #E8EDF6;
	}

	.article-content strong {
		color: #F5B544;
		font-weight: 600;
	}
</style>
