---
interface Props {
	label: string;
	value: number;
	suffix?: string;
}

const { label, value, suffix = '' } = Astro.props;
const statId = `stat-${Math.random().toString(36).substr(2, 9)}`;
---

<div class="text-center">
	<div class="mb-3 text-5xl font-bold font-display text-foreground md:text-6xl lg:text-7xl">
		<span id={statId} class="stat-counter" data-value={value}>0</span>
		<span class="text-primary">{suffix}</span>
	</div>
	<p class="text-sm font-semibold uppercase tracking-[0.2em] text-foreground/60 md:text-base">
		{label}
	</p>
</div>

<script>
	const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

	if (!prefersReducedMotion) {
		const statElement = document.getElementById(statId);
		if (statElement) {
			const targetValue = parseInt(statElement.dataset.value || '0');
			const duration = 2000;
			const startTime = performance.now();
			
			const observer = new IntersectionObserver((entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						const animate = (currentTime: number) => {
							const elapsed = currentTime - startTime;
							const progress = Math.min(elapsed / duration, 1);
							const easeOutQuart = 1 - Math.pow(1 - progress, 4);
							const currentValue = Math.floor(easeOutQuart * targetValue);
							
							statElement.textContent = currentValue.toLocaleString();
							
							if (progress < 1) {
								requestAnimationFrame(animate);
							} else {
								statElement.textContent = targetValue.toLocaleString();
							}
						};
						
						requestAnimationFrame(animate);
						observer.unobserve(entry.target);
					}
				});
			}, { threshold: 0.5 });
			
			observer.observe(statElement);
		}
	}
</script>
