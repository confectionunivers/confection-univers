---
/**
 * Grille de services — images dans public/images/services/
 * Fichiers : graduation.jpg, scolaire.jpg, travail.jpg, sport.jpg,
 * blouses-medicales.jpg, sages-femmes.jpg, infirmiers.jpg, docteurs.jpg
 */
const services = [
	{
		title: 'Tenues de graduation',
		description:
			'Toges et ensembles sur mesure pour cérémonies mémorables, finissants et photos d’exception.',
		image: '/images/services/graduation.jpg',
	},
	{
		title: 'Uniformes scolaires',
		description:
			'Identité d’établissement : vestes, polos, tabliers et pièces coordonnées, durables et soignées.',
		image: '/images/services/scolaire.jpg',
	},
	{
		title: 'Tenues de travail',
		description:
			'Vêtements professionnels adaptés à votre secteur, confort au quotidien et image de marque cohérente.',
		image: '/images/services/travail.jpg',
	},
	{
		title: 'Tenues de sport',
		description:
			'Maillots, ensembles d’équipe et pièces techniques personnalisées pour clubs et organisations.',
		image: '/images/services/sport.jpg',
	},
	{
		title: 'Blouses médicales',
		description:
			'Blouses cliniques confortables, coupes ergonomiques et tissus pensés pour l’entretien intensif.',
		image: '/images/services/blouses-medicales.jpg',
	},
	{
		title: 'Tenues pour sages-femmes',
		description:
			'Tenues dédiées à l’accompagnement à la naissance : confort, mobilité et élégance discrète.',
		image: '/images/services/sages-femmes.jpg',
	},
	{
		title: 'Tenues pour infirmiers',
		description:
			'Uniformes soignants fonctionnels, poches pratiques et tenues qui tiennent des quarts prolongés.',
		image: '/images/services/infirmiers.jpg',
	},
	{
		title: 'Tenues pour docteurs',
		description:
			'Blancs médicaux raffinés pour cabinets et milieux hospitaliers : stature professionnelle assurée.',
		image: '/images/services/docteurs.jpg',
	},
];
---

<section
	id="services"
	class="relative z-10 scroll-mt-24 rounded-[3rem] border border-ink/5 bg-paper py-24 text-ink shadow-[0_24px_80px_-28px_rgba(5,10,20,0.14)] md:rounded-[4rem] md:py-32"
	lang="fr"
	aria-labelledby="services-heading"
>
	<div class="mx-auto max-w-7xl px-6">
		<div class="mx-auto mb-16 max-w-3xl text-center md:mb-20">
			<p class="mb-4 text-[11px] font-semibold uppercase tracking-[0.35em] text-primary md:text-xs">Nos expertises</p>
			<h2 id="services-heading" class="font-display text-4xl font-semibold leading-tight tracking-tight text-ink md:text-5xl lg:text-6xl">
				Des services sur mesure pour chaque besoin
			</h2>
			<p class="mt-6 text-base leading-relaxed text-ink/65 md:text-lg">
				De la graduation aux milieux de santé, nous confectionnons des tenues qui allient précision, confort et
				distinction.
			</p>
		</div>

		<div
			class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4"
		>
			{
				services.map((s, i) => (
					<article
						class="service-card group relative flex flex-col overflow-hidden rounded-2xl border border-ink/10 bg-paper shadow-[0_4px_24px_-8px_rgba(5,10,20,0.08)] transition duration-500 ease-out will-change-transform hover:-translate-y-2 hover:border-primary/35 hover:shadow-[0_28px_56px_-16px_rgba(5,10,20,0.18)]"
					>
						<div class="relative aspect-[4/3] overflow-hidden bg-surface/40">
							<img
								src={s.image}
								alt={s.title}
								class="service-card-img h-full w-full object-cover transition duration-700 ease-out"
								width="640"
								height="480"
								loading={i < 4 ? 'eager' : 'lazy'}
								decoding="async"
							/>
							<div
								class="pointer-events-none absolute inset-0 bg-gradient-to-t from-ink/25 via-transparent to-transparent opacity-0 transition duration-500 group-hover:opacity-100"
								aria-hidden="true"
							/>
							<span
								class="absolute left-4 top-4 flex h-9 w-9 items-center justify-center rounded-full border border-primary/30 bg-background/85 font-display text-xs font-semibold text-primary backdrop-blur-sm transition duration-500 group-hover:border-primary group-hover:bg-primary group-hover:text-background"
								aria-hidden="true"
							>
								{String(i + 1).padStart(2, '0')}
							</span>
						</div>

						<div class="flex flex-1 flex-col p-6 md:p-7">
							<h3 class="font-display text-xl font-semibold leading-snug tracking-tight text-ink transition duration-300 group-hover:text-primary md:text-[1.35rem]">
								{s.title}
							</h3>
							<p class="mt-3 flex-1 text-sm leading-relaxed text-ink/65 md:text-[0.9375rem]">{s.description}</p>
							<span
								class="mt-5 inline-flex items-center gap-2 text-[11px] font-semibold uppercase tracking-[0.2em] text-primary opacity-90 transition duration-300 group-hover:gap-3"
							>
								En savoir plus
								<svg class="h-3.5 w-3.5 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
									<path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 6l6 6-6 6" />
								</svg>
							</span>
						</div>
					</article>
				))
			}
		</div>

		<div class="mt-16 flex flex-col items-center justify-center gap-4 border-t border-primary/10 pt-12 text-center md:mt-20 md:flex-row md:gap-8">
			<p class="max-w-md text-sm text-ink/55 md:text-base">Un projet spécifique ? Nous adaptons coupe, tissus et finitions à votre institution.</p>
			<a
				href="/contact"
				class="inline-flex shrink-0 items-center justify-center rounded-full border border-primary/40 bg-ink px-8 py-3.5 text-[12px] font-semibold uppercase tracking-[0.18em] text-paper transition duration-400 hover:bg-primary hover:text-background"
			>
				Demander un devis
			</a>
		</div>
	</div>
</section>

<style>
	@media (prefers-reduced-motion: no-preference) {
		.service-card:hover .service-card-img {
			transform: scale(1.06);
		}
	}
	@media (prefers-reduced-motion: reduce) {
		.service-card {
			transition: none;
		}
		.service-card:hover {
			transform: none;
		}
	}
</style>
