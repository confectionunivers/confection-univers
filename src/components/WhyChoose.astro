---
---

<section class="scroll-mt-24 premium-section py-32 border-0">
	<!-- Premium Golden Glow -->
	<div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
		<div class="absolute left-[10%] top-[25%] w-[500px] h-[500px] rounded-full" style="background: radial-gradient(ellipse, rgba(250, 204, 107, 0.12) 0%, transparent 70%); filter: blur(100px);"></div>
		<div class="absolute right-[10%] bottom-[25%] w-[400px] h-[400px] rounded-full" style="background: radial-gradient(ellipse, rgba(250, 204, 107, 0.08) 0%, transparent 70%); filter: blur(80px);"></div>
	</div>

	<div class="mx-auto max-w-7xl px-6">
		<div class="mb-24 text-center">
			<div class="reveal-view mb-6 text-[11px] font-semibold uppercase tracking-[0.2em] premium-subtitle">
				Pourquoi les institutions nous font confiance
			</div>

			<h2
				class="reveal-view mx-auto max-w-5xl font-display text-2xl md:text-3xl font-semibold text-[#F9FAFB] text-center mb-12 tracking-tight"
			>
				Professionnalisme et qualité, Respect des delais
			</h2>
		</div>

		<div class="grid auto-rows-[320px] grid-cols-1 gap-6 md:grid-cols-12">
			<div
				class="group relative overflow-hidden rounded-[1.5rem] border border-[rgba(250,204,107,0.25)] p-6 md:p-8 w-full h-full transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl hover:border-[rgba(250,204,107,0.4)] md:col-span-8 premium-card"
			>
				<img
					src="/images/respect-delais.jpg"
					class="absolute inset-0 w-full h-full object-cover z-0 pointer-events-none opacity-90"
					alt=""
				/>

				<div class="absolute right-0 top-0 flex h-full w-1/2 items-center justify-center opacity-10 transition-opacity duration-700 group-hover:opacity-20">
					<svg class="h-48 w-48 text-[#FACC6B]" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
					</svg>
				</div>

				<div class="relative z-20 flex h-full max-w-sm flex-col justify-between">
					<div class="relative z-20">
						<span class="relative z-20 text-[11px] font-semibold uppercase tracking-[0.2em] premium-subtitle">
							Consultation gratuite
						</span>

						<h3 class="mt-6 font-display text-lg font-semibold text-[#F9FAFB] mb-2 relative z-20">
							Discutez de vos besoins en uniformes avec notre équipe.
						</h3>
					</div>

					<a
						href="/contact"
						class="group relative inline-flex min-h-[3.25rem] items-center justify-center overflow-hidden rounded-full px-8 py-3.5 text-center text-[13px] font-semibold uppercase tracking-[0.18em] text-background transition-all duration-500"
						style="background: linear-gradient(135deg, #FACC6B 0%, #F59E0B 50%, #D97706 100%); box-shadow: inset 0 1px 0 rgba(255,255,255,0.15), 0 18px 40px rgba(0, 0, 0, 0.50); border: 1px solid rgba(161, 98, 7, 0.7);"
					>
						<span class="relative z-10 transition-transform duration-300 group-hover:scale-[1.02]">Demander une consultation</span>
						<span class="absolute inset-0 rounded-full border-2 border-primary/0 transition-all duration-500 group-hover:border-primary/50 group-hover:shadow-[0_0_30px_rgba(198,161,95,0.4)]"></span>
					</a>
				</div>
			</div>

			<div
				class="group relative flex flex-col justify-between overflow-hidden rounded-[1.5rem] p-6 md:p-8 text-background transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl hover:brightness-110 md:col-span-4"
				style="background: linear-gradient(135deg, #FACC6B 0%, #F59E0B 50%, #D97706 100%);"
			>
				<div class="font-display text-2xl font-bold tracking-tight mb-1 relative z-10" style="color: #00002a;">
					L'excellence à chaque couture
				</div>

				<div class="relative z-10">
					<h3 class="mb-2 text-lg font-semibold text-white relative z-10">
						Cérémonies de graduation
					</h3>

					<p class="text-sm text-white/90 font-normal leading-[1.6] relative z-10">
						Toges confectionnées pour les cérémonies de remise des diplômes des universités et grandes écoles.
					</p>
				</div>
			</div>

			<div
				class="group relative flex flex-col justify-between overflow-hidden rounded-[1.5rem] border border-[rgba(250,204,107,0.25)] p-6 md:p-8 w-full h-full transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl hover:border-[rgba(250,204,107,0.4)] md:col-span-4 premium-card-secondary"
			>
				<img
					src="/images/qualite-tissu.jpg"
					class="absolute inset-0 w-full h-full object-cover z-0 pointer-events-none opacity-90"
					alt=""
				/>

				<div class="relative z-20">
					<svg class="relative z-20 w-5 h-5 text-[#FACC6B] mb-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
					</svg>
				</div>

				<div class="relative z-20">
					<h3 class="font-display text-3xl font-bold text-[#FACC6B] tracking-tight mb-1 relative z-20" style="text-shadow: 2px 2px 4px rgba(0,0,0,0.8), -1px -1px 2px rgba(0,0,0,0.8), 1px -1px 2px rgba(0,0,0,0.8), -1px 1px 2px rgba(0,0,0,0.8);">
						+5 ans
					</h3>
					<p class="text-sm text-[#FACC6B] font-normal relative z-20 leading-[1.6]" style="text-shadow: 2px 2px 4px rgba(0,0,0,0.8), -1px -1px 2px rgba(0,0,0,0.8), 1px -1px 2px rgba(0,0,0,0.8), -1px 1px 2px rgba(0,0,0,0.8);">
						d'expertise au service des institutions.
					</p>
				</div>
			</div>

			<div
				class="group relative flex flex-col justify-between overflow-hidden rounded-[1.5rem] border border-[rgba(250,204,107,0.25)] p-6 md:p-8 w-full h-full transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl hover:border-[rgba(250,204,107,0.4)] md:col-span-5 premium-card"
			>
				<img
					src="/images/finitions-professionnelles.jpg"
					class="absolute inset-0 w-full h-full object-cover z-0 pointer-events-none opacity-90"
					alt=""
				/>

				<div class="relative z-20">
					<h3 class="mb-2 text-lg font-semibold text-[#FACC6B] relative z-20" style="text-shadow: 0 0 20px rgba(250, 204, 107, 0.8), 0 0 40px rgba(250, 204, 107, 0.6), 2px 2px 4px rgba(0,0,0,0.8);">
						Qualité certifiée
					</h3>

					<p class="text-sm text-[#FACC6B] font-normal relative z-20 leading-[1.6]" style="text-shadow: 0 0 15px rgba(250, 204, 107, 0.6), 2px 2px 4px rgba(0,0,0,0.8);">
						Processus de fabrication certifiés ISO assurant une qualité constante dans toutes les productions.
					</p>
				</div>

				<div class="space-y-2 text-sm text-[#FACC6B] relative z-20" style="text-shadow: 0 0 15px rgba(250, 204, 107, 0.6), 2px 2px 4px rgba(0,0,0,0.8);">
					<p>• Traçabilité totale des lots textiles</p>
					<p>• Contrôle qualité à chaque étape de coupe</p>
					<p>• Certification ISO 9001 conforme</p>
				</div>
			</div>

			<div
				class="group relative overflow-hidden rounded-[1.5rem] bg-[rgba(0,0,0,0.3)] transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl hover:border-[rgba(250,204,107,0.3)] border border-[rgba(250,204,107,0.15)] md:col-span-3 premium-card-secondary"
			>
				<img
					src="/images/blouse-medicale.jpg"
					class="h-full w-full object-contain transition-transform duration-700 hover:scale-110"
					alt="Inspection du contrôle qualité"
				/>
			</div>
		</div>
	</div>
</section>