---
---

<section class="bg-background py-32">
	<div class="mx-auto max-w-7xl px-6">
		<div class="mb-24 text-center">
			<div class="reveal-view mb-6 text-sm font-black uppercase tracking-[0.3em] text-primary">
				{'{ 02 }'} # Pourquoi les institutions nous font confiance
			</div>

			<h2
				class="reveal-view mx-auto max-w-5xl font-display text-5xl font-bold leading-[0.9] tracking-tighter text-foreground lg:text-8xl"
			>
				Confection de précision : Toges de graduation, Tenues de travail, Uniformes scolaires et Tenues de sport
			</h2>
		</div>

		<div class="grid auto-rows-[320px] grid-cols-1 gap-6 md:grid-cols-12">
			<div
				class="group relative overflow-hidden rounded-[3rem] border border-primary/10 bg-surface p-12 transition-transform duration-300 hover:-translate-y-2 md:col-span-8"
			>
				<img
					src="/images/about-facility.jpg"
					class="absolute right-0 top-0 h-full w-1/2 object-contain opacity-25 transition-opacity duration-700 group-hover:opacity-50"
					alt="Installation de confection"
				/>

				<div class="relative z-10 flex h-full max-w-sm flex-col justify-between">
					<div>
						<span class="text-[11px] font-black uppercase tracking-[0.2em] text-primary">
							Consultation gratuite
						</span>

						<h3 class="mt-6 font-display text-5xl font-bold leading-tight text-foreground">
							Discutez de vos besoins en uniformes avec notre équipe.
						</h3>
					</div>

					<a
						href="/contact"
						class="w-fit rounded-full border border-primary/40 bg-primary/10 px-10 py-4 text-[11px] font-black uppercase tracking-widest text-primary transition hover:bg-primary hover:text-background"
					>
						Demander une consultation
					</a>
				</div>
			</div>

			<div
				class="flex flex-col justify-between rounded-[3rem] bg-primary p-12 text-background transition-transform duration-300 hover:-translate-y-2 md:col-span-4"
			>
				<div class="font-display text-8xl font-bold tracking-tighter text-background">
					250K+
				</div>

				<div>
					<h3 class="mb-3 text-3xl font-bold text-background">
						Production annuelle
					</h3>

					<p class="text-sm font-medium leading-relaxed text-background/75">
						Capacité de production pour gérer les commandes importantes avec une qualité constante.
					</p>
				</div>
			</div>

			<div
				class="flex flex-col justify-between rounded-[3rem] border border-primary/10 bg-surface p-12 transition-transform duration-300 hover:-translate-y-2 md:col-span-4"
			>
				<div class="text-[11px] font-black uppercase tracking-[0.3em] text-foreground/35">
					(Depuis 2010)
				</div>

				<h3 class="font-display text-4xl font-bold text-foreground">
					15+ ans d'expérience
				</h3>
			</div>

			<div
				class="flex flex-col justify-between rounded-[3rem] border border-primary/10 bg-surface p-12 transition-transform duration-300 hover:-translate-y-2 md:col-span-5"
			>
				<div>
					<h3 class="mb-4 text-3xl font-bold text-foreground">
						Qualité certifiée
					</h3>

					<p class="text-sm font-medium text-foreground/50">
						Processus de fabrication certifiés ISO assurant une qualité constante dans toutes les productions.
					</p>
				</div>

				<div class="grid grid-cols-4 gap-4 opacity-25">
					{[1, 2, 3, 4, 5, 6, 7, 8].map((i) => (
						<div class="h-10 rounded-xl border border-primary/15 bg-primary/10" />
					))}
				</div>
			</div>

			<div
				class="overflow-hidden rounded-[3rem] bg-surface-elevated transition-transform duration-300 hover:-translate-y-2 md:col-span-3"
			>
				<img
					src="/images/blouse-medicale.jpg"
					class="h-full w-full object-contain transition-transform duration-700 hover:scale-110"
					alt="Inspection du contrôle qualité"
				/>
			</div>
		</div>
	</div>
</section>