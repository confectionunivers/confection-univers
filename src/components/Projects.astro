---
const PROJECTS = [
	{
		title: 'Social Media Engagement Growth',
		img: 'pro1.webp',
		cat: 'Growth Strategy',
		year: '2026',
	},
	{
		title: 'Complete Branding & Strategy',
		img: 'pro2.webp',
		cat: 'Branding',
		year: '2025',
	},
	{
		title: 'Multi-Channel Performance Marketing',
		img: 'pro3.webp',
		cat: 'Marketing',
		year: '2026',
	},
];
---

<section class="bg-background py-32">
	<div class="mx-auto max-w-7xl px-6">
		<div
			class="mb-24 flex flex-col items-center justify-between gap-8 border-b border-primary/15 pb-16 md:flex-row"
		>
			<div class="text-sm font-black uppercase tracking-[0.3em] text-primary">{'{ 05 }'} # Our Works</div>
			<div class="font-display text-4xl font-bold uppercase italic tracking-tighter text-foreground md:text-6xl">
				Stories We've Told
			</div>
		</div>

		<div class="space-y-24">
			{
				PROJECTS.map((p) => (
					<div class="sticky top-32 grid items-center gap-16 border-t border-primary/10 bg-background py-16 lg:grid-cols-2">
						<div class="group relative aspect-[16/10] overflow-hidden rounded-[3.5rem] shadow-2xl ring-1 ring-primary/10">
							<img
								src={`https://themexriver.com/wp/noryx/wp-content/uploads/2026/03/${p.img}`}
								class="h-full w-full object-cover transition-transform duration-1000 group-hover:scale-110"
								alt={p.title}
							/>
							<div class="pointer-events-none absolute inset-0 bg-background/25 transition-colors group-hover:bg-transparent" />
						</div>

						<div class="reveal-view space-y-10">
							<div class="flex gap-10 text-[11px] font-black uppercase tracking-[0.3em] text-foreground/45">
								<div>Year: {p.year}</div>
								<div>Category: {p.cat}</div>
							</div>
							<h3 class="font-display text-5xl font-bold uppercase leading-[0.9] tracking-tighter text-foreground lg:text-7xl">
								{p.title}
							</h3>
							<p class="max-w-md text-lg font-medium text-foreground/50">
								We helped our clients achieve a 300% increase in organic reach through data-driven content
								strategies.
							</p>
							<button
								type="button"
								class="rounded-full border border-primary/30 bg-paper px-12 py-5 text-[11px] font-black uppercase tracking-widest text-ink transition hover:scale-105 hover:bg-primary hover:text-background"
							>
								View Details
							</button>
						</div>
					</div>
				))
			}
		</div>
	</div>
</section>
