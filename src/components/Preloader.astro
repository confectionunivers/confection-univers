<div
	id="preloader"
	class="fixed inset-0 z-[100] flex items-center justify-center bg-background"
	aria-live="polite"
	aria-busy="true"
>
	<div class="relative h-24 w-24">
		<div class="absolute inset-0 rounded-full border-4 border-primary/25"></div>
		<div
			class="absolute inset-0 animate-preloader-spin rounded-full border-4 border-transparent border-t-primary"
		>
		</div>
		<div class="absolute inset-0 flex items-center justify-center">
			<span class="font-display text-xs font-semibold tracking-[0.2em] text-primary">CU</span>
		</div>
	</div>
</div>

<script>
	const root = document.getElementById('preloader');
	if (root) {
		window.setTimeout(() => {
			root.classList.add('preloader--exit');
			const done = () => {
				root.remove();
			};
			root.addEventListener('transitionend', done, { once: true });
			window.setTimeout(done, 1000);
		}, 2000);
	}
</script>
