---
---

<section class="relative z-10 -mt-10 rounded-[4rem] bg-paper py-32 text-ink shadow-[0_-20px_80px_-20px_rgba(5,10,20,0.15)]">
	<div class="mx-auto max-w-7xl px-6">
		<div class="flex flex-col gap-24 lg:flex-row">
			<div class="lg:w-1/3">
				<div class="sticky top-32 space-y-16">
					<div class="text-sm font-black uppercase tracking-[0.3em] text-primary">
						{'{ 01 }'} # About Us
					</div>

					<div class="space-y-12">
						<div class="border-b border-ink/10 pb-10">
							<div
								class="mb-6 flex items-center justify-between text-[11px] font-black uppercase tracking-widest text-ink/40"
							>
								<span>Clients satisfaits</span>
								<span class="text-primary">★</span>
							</div>
							<div class="font-display text-7xl font-bold tracking-tighter text-ink">500+</div>
							<p class="mt-4 max-w-[200px] text-sm font-medium text-ink/60">
								Les institutions et entreprises font confiance à notre qualité
							</p>
						</div>

						<div class="border-b border-ink/10 pb-10">
							<div
								class="mb-6 flex items-center justify-between text-[11px] font-black uppercase tracking-widest text-ink/40"
							>
								<span>Vêtements produits</span>
								<span class="text-primary">�</span>
							</div>
							<div class="font-display text-7xl font-bold tracking-tighter text-ink">250K+</div>
							<p class="mt-4 max-w-[200px] text-sm font-medium text-ink/60">
								Uniformes et vêtements fabriqués annuellement
							</p>
						</div>
					</div>
				</div>
			</div>

			<div class="lg:w-2/3">
				<h2
					class="reveal-view mb-20 font-display text-5xl font-bold leading-[1.1] tracking-tight text-ink lg:text-7xl"
				>
					Confection Univers est un fabricant professionnel de vêtements offrant des uniformes de qualité et des solutions
					de vêtements personnalisés pour les institutions à travers le Canada.
				</h2>

				<div class="grid gap-16 md:grid-cols-2">
					<div class="about-parallax-img aspect-[3/4] overflow-hidden rounded-[3rem] bg-surface/10 shadow-2xl ring-1 ring-primary/10">
						<img
							src="/images/about-manufacturing.jpg"
							class="h-full w-full object-cover"
							alt="Installation de confection de vêtements"
						/>
					</div>

					<div class="space-y-12 pt-12">
						<div class="space-y-6">
							<div class="flex items-center gap-5">
								<div
									class="flex h-14 w-14 items-center justify-center rounded-full bg-primary/12 text-2xl text-primary"
								>
									🎯
								</div>
								<h4 class="text-sm font-black uppercase tracking-widest text-ink">Notre mission</h4>
							</div>
							<p class="text-lg font-medium leading-relaxed text-ink/65">
								Délivrer une confection de vêtements exceptionnelle avec un artisanat de précision, une capacité de production fiable,
								et un engagement inébranlable envers la qualité pour chaque commande client.
							</p>
						</div>

						<div class="flex items-center gap-6 border-t border-ink/10 pt-12">
							<div class="relative">
								<img
									src="/images/founder.jpg"
									class="h-16 w-16 rounded-full border-2 border-primary/35 object-cover"
									alt="Marie Tremblay"
								/>
								<div
									class="absolute -bottom-1 -right-1 flex h-6 w-6 items-center justify-center rounded-full bg-primary text-[10px] text-background"
								>
									✓
								</div>
							</div>
							<div>
								<div class="text-xl font-bold text-ink">Marie Tremblay</div>
								<div class="text-[11px] font-black uppercase tracking-[0.2em] text-ink/45">
									Directrice de production & Fondatrice
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
