---
---

<style>
	.about-section {
		background: #00001C;
		position: relative;
		overflow: hidden;
	}

	.about-image-container {
		position: relative;
		border-radius: 22px 22px 22px 0;
		overflow: hidden;
	}

	.about-image-container::before {
		content: '';
		position: absolute;
		top: 0;
		right: 0;
		width: 60px;
		height: 60px;
		background: #00001C;
		border-radius: 0 0 0 60px;
		z-index: 10;
	}

	.about-badge {
		position: absolute;
		bottom: 1.5rem;
		left: 1.5rem;
		background: rgba(14, 23, 42, 0.9);
		backdrop-filter: blur(10px);
		border: 1px solid #1C2A46;
		border-radius: 16px;
		padding: 0.75rem 1rem;
		display: flex;
		align-items: center;
		gap: 0.75rem;
		z-index: 10;
	}

	.mission-card {
		background: #F5B544;
		border-radius: 16px;
		padding: 1.5rem;
		cursor: pointer;
		transition: all 0.3s ease;
	}

	.mission-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 12px 28px rgba(245,181,68,0.35);
	}

	.vision-card {
		background: #0E172A;
		border: 1px solid #1C2A46;
		border-radius: 16px;
		padding: 1.5rem;
		cursor: pointer;
		transition: all 0.3s ease;
	}

	.vision-card:hover {
		border-color: #F5B544;
		transform: translateY(-4px);
	}

	.cta-button {
		background: #F5B544;
		border-radius: 9999px;
		padding: 0.75rem 1.5rem;
		font-weight: 600;
		transition: all 0.3s ease;
	}

	.cta-button:hover {
		background: #F19A1A;
		transform: translateY(-2px);
		box-shadow: 0 12px 28px rgba(245,181,68,0.35);
	}

	@media (max-width: 1023px) {
		.about-image-container {
			border-radius: 22px;
		}
	}
</style>

<section class="about-section py-20 md:py-32">
	<!-- Background Glow -->
	<div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
		<div class="absolute left-[10%] top-[20%] w-[500px] h-[500px] rounded-full" style="background: radial-gradient(ellipse, rgba(245, 181, 68, 0.08) 0%, transparent 70%); filter: blur(120px);"></div>
		<div class="absolute right-[15%] bottom-[30%] w-[400px] h-[400px] rounded-full" style="background: radial-gradient(ellipse, rgba(245, 181, 68, 0.06) 0%, transparent 70%); filter: blur(100px);"></div>
	</div>

	<div class="mx-auto max-w-7xl px-6 md:px-10">
		<div class="grid gap-12 lg:grid-cols-2 lg:gap-16 items-center">
			<!-- Left: Image with asymmetric design -->
			<div class="about-image-wrapper relative">
				<div class="about-image-container aspect-[4/5]">
					<img
						src="/images/about-facility.jpg"
						alt="Atelier de confection Confection Univers"
						class="w-full h-full object-cover"
						loading="lazy"
					/>
				</div>
				<!-- Floating Badge -->
				<div class="about-badge">
					<div class="relative">
						<img
							src="/images/logo.png"
							class="h-10 w-10 rounded-full object-cover border-2 border-[#F5B544]"
							alt="Directeur"
						/>
					</div>
					<div>
						<div class="text-xs font-bold uppercase tracking-wider" style="color: #F5B544;">Mot du Directeur</div>
						<div class="text-sm font-semibold" style="color: #FFFFFF;">Mme Adja.D.Faye</div>
					</div>
				</div>
			</div>

			<!-- Right: Content -->
			<div class="about-content space-y-8">
				<!-- Subtitle -->
				<div class="text-xs font-black uppercase tracking-[0.25em]" style="color: #F5B544;">
					•  À PROPOS DE NOUS
				</div>

				<!-- Title -->
				<h2 class="text-3xl md:text-4xl lg:text-5xl font-bold font-display leading-tight" style="color: #FFFFFF;">
					L'excellence de la confection
					<span style="color: #F5B544;"> industrielle</span> au service de votre image.
				</h2>

				<!-- Sub-grid -->
				<div class="grid gap-6 md:grid-cols-2">
					<!-- Left: Stats Counter -->
					<div class="space-y-4">
						<div class="text-4xl md:text-5xl font-bold font-display" style="color: #FFFFFF;">
							+5 <span class="text-xl md:text-2xl font-medium" style="color: #A0ACC6;">Ans d'Expérience</span>
						</div>
						<p class="text-sm leading-relaxed" style="color: #A0ACC6;">
							Des années de savoir-faire dans la confection de tenues professionnelles et d'uniformes de qualité.
						</p>
						<a href="https://confectionunivers.com/about" class="btn-hero-primary">
							<span>En savoir plus</span>
							<svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
							</svg>
						</a>
					</div>

					<!-- Right: Mission/Vision Tabs -->
					<div class="space-y-3">
						<div class="mission-card">
							<div class="flex items-center gap-3 mb-2">
								<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
								</svg>
								<h3 class="font-bold text-white">Notre Mission</h3>
							</div>
							<p class="text-sm text-white/90">
								Fournir des tenues de qualité exceptionnelle qui incarnent la rigueur et l'identité de chaque institution.
							</p>
						</div>
						<div class="vision-card">
							<div class="flex items-center gap-3 mb-2">
								<svg class="w-6 h-6" style="color: #F5B544;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
									<path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
								</svg>
								<h3 class="font-bold" style="color: #FFFFFF;">Notre Vision</h3>
							</div>
							<p class="text-sm" style="color: #A0ACC6;">
								Devenir le partenaire de référence pour toutes les institutions en quête d'excellence vestimentaire.
							</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';

	if (typeof window !== 'undefined') {
		gsap.registerPlugin(ScrollTrigger);

		let ctx: gsap.Context | null = null;

		const init = () => {
			const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

			if (!prefersReducedMotion) {
				ctx = gsap.context(() => {
					const section = document.querySelector('.about-section');
					const imageWrapper = document.querySelector('.about-image-wrapper');
					const content = document.querySelector('.about-content');
					const badge = document.querySelector('.about-badge');
					const missionCard = document.querySelector('.mission-card');
					const visionCard = document.querySelector('.vision-card');
					const ctaButton = document.querySelector('.cta-button');

					if (section) {
						// Create timeline
						const tl = gsap.timeline({
							scrollTrigger: {
								trigger: section,
								start: 'top 80%',
								end: 'bottom 20%',
								toggleActions: 'play none none reverse'
							}
						});

						// Image parallax/fade up
						if (imageWrapper) {
							gsap.set(imageWrapper, { y: 50, opacity: 0 });
							tl.to(imageWrapper, {
								y: 0,
								opacity: 1,
								duration: 1,
								ease: 'power3.out'
							}, 0);
						}

						// Badge fade in
						if (badge) {
							gsap.set(badge, { y: 30, opacity: 0 });
							tl.to(badge, {
								y: 0,
								opacity: 1,
								duration: 0.8,
								ease: 'power3.out'
							}, 0.3);
						}

						// Content stagger reveal
						if (content) {
							const subtitle = content.querySelector('.text-xs') as HTMLElement;
							const title = content.querySelector('h2') as HTMLElement;
							const subGrid = content.querySelector('.grid') as HTMLElement;

							if (subtitle) {
								gsap.set(subtitle, { y: 30, opacity: 0 });
								tl.to(subtitle, {
									y: 0,
									opacity: 1,
									duration: 0.6,
									ease: 'power3.out'
								}, 0.2);
							}

							if (title) {
								gsap.set(title, { y: 30, opacity: 0 });
								tl.to(title, {
									y: 0,
									opacity: 1,
									duration: 0.8,
									ease: 'power3.out'
								}, 0.4);
							}

							if (subGrid) {
								gsap.set(subGrid, { y: 30, opacity: 0 });
								tl.to(subGrid, {
									y: 0,
									opacity: 1,
									duration: 0.8,
									ease: 'power3.out'
								}, 0.6);
							}
						}

						// Cards sequential appearance
						if (missionCard && visionCard) {
							gsap.set([missionCard as HTMLElement, visionCard as HTMLElement], { y: 20, opacity: 0 });
							tl.to(missionCard as HTMLElement, {
								y: 0,
								opacity: 1,
								duration: 0.6,
								ease: 'power3.out'
							}, 0.8);
							tl.to(visionCard as HTMLElement, {
								y: 0,
								opacity: 1,
								duration: 0.6,
								ease: 'power3.out'
							}, 1);
						}

						// CTA button
						if (ctaButton) {
							gsap.set(ctaButton as HTMLElement, { scale: 0.9, opacity: 0 });
							tl.to(ctaButton as HTMLElement, {
								scale: 1,
								opacity: 1,
								duration: 0.5,
								ease: 'back.out(1.7)'
							}, 1.2);
						}

						// Hover effects with GSAP
						if (missionCard) {
							missionCard.addEventListener('mouseenter', () => {
								gsap.to(missionCard as HTMLElement, {
									y: -4,
									duration: 0.3,
									ease: 'power2.out'
								});
							});
							missionCard.addEventListener('mouseleave', () => {
								gsap.to(missionCard as HTMLElement, {
									y: 0,
									duration: 0.3,
									ease: 'power2.out'
								});
							});
						}

						if (visionCard) {
							visionCard.addEventListener('mouseenter', () => {
								gsap.to(visionCard as HTMLElement, {
									y: -4,
									duration: 0.3,
									ease: 'power2.out'
								});
							});
							visionCard.addEventListener('mouseleave', () => {
								gsap.to(visionCard as HTMLElement, {
									y: 0,
									duration: 0.3,
									ease: 'power2.out'
								});
							});
						}

						if (ctaButton) {
							ctaButton.addEventListener('mouseenter', () => {
								gsap.to(ctaButton as HTMLElement, {
									y: -2,
									duration: 0.3,
									ease: 'power2.out'
								});
							});
							ctaButton.addEventListener('mouseleave', () => {
								gsap.to(ctaButton as HTMLElement, {
									y: 0,
									duration: 0.3,
									ease: 'power2.out'
								});
							});
						}

						// Parallax effect on image
						if (imageWrapper) {
							gsap.to(imageWrapper as HTMLElement, {
								y: -30,
								scrollTrigger: {
									trigger: section,
									start: 'top bottom',
									end: 'bottom top',
									scrub: 1.5
								}
							});
						}
					}
				});
			}
		};

		const cleanup = () => {
			if (ctx) {
				ctx.revert();
				ctx = null;
			}
			ScrollTrigger.getAll().forEach(t => t.kill());
		};

		const ready = () => init();
		if (document.readyState !== 'loading') ready();
		else window.addEventListener('DOMContentLoaded', ready, { once: true });

		document.addEventListener('astro:before-swap', cleanup, { once: true });
		window.addEventListener('pagehide', cleanup, { once: true });
	}
</script>
