---
interface Props {
	milestones: Array<{ year: string; title: string; description: string }>;
}

const { milestones } = Astro.props;
---

<div class="relative">
	<!-- Vertical Line -->
	<div class="absolute left-8 top-0 bottom-0 w-0.5 bg-gradient-to-b from-primary/50 via-primary/30 to-transparent md:left-1/2 md:-translate-x-1/2" aria-hidden="true"></div>
	
	{milestones.map((milestone, index) => (
		<div class={`relative mb-12 md:mb-16 ${index % 2 === 0 ? 'md:pr-1/2 md:text-right' : 'md:pl-1/2 md:ml-auto'}`} style="animation-delay: `${index * 100}ms`">
			<!-- Dot -->
			<div class={`absolute left-8 top-0 flex h-5 w-5 -translate-x-1/2 items-center justify-center rounded-full border-4 border-background bg-primary md:left-1/2 ${index % 2 === 0 ? 'md:-translate-x-1/2' : 'md:translate-x-1/2'}`} aria-hidden="true">
				<div class="h-2 w-2 rounded-full bg-primary"></div>
			</div>
			
			<!-- Content -->
			<div class={`ml-16 md:ml-0 ${index % 2 === 0 ? 'md:pr-12' : 'md:pl-12'}`}>
				<div class="mb-2 text-3xl font-bold font-display text-primary">{milestone.year}</div>
				<h3 class="mb-2 text-xl font-semibold font-display text-foreground">{milestone.title}</h3>
				<p class="text-base leading-relaxed text-foreground/70">{milestone.description}</p>
			</div>
		</div>
	))}
</div>

<style>
	@media (prefers-reduced-motion: no-preference) {
		.timeline-item {
			opacity: 0;
			transform: translateY(20px);
			animation: fade-up 0.5s ease-out forwards;
		}
		
		@keyframes fade-up {
			to {
				opacity: 1;
				transform: translateY(0);
			}
		}
	}
</style>
