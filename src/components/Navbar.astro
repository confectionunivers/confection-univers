---
const NAV_LINKS = [
	{ label: 'Accueil', href: '/' },
	{ label: 'À propos', href: '/about' },
	{ label: 'Services', href: '/services' },
	{ label: 'Produits', href: '/products' },
	{ label: 'Projets', href: '/projects' },
	{ label: 'Contact', href: '/contact' },
];

const contactInfo = {
	email: 'confectionunivers@gmail.com',
	phone: '+221 77 296 07 76',
};
---

<header class="fixed top-0 left-0 right-0 z-[60]">
	<!-- Top Bar -->
	<div class="top-bar">
		<div class="flex items-center gap-6">
			<a
				href={`mailto:${contactInfo.email}`}
				class="flex items-center gap-2 text-xs font-medium tracking-wide transition-colors hover:text-gray-300"
			>
				<svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
				</svg>
				<span class="hidden sm:inline">{contactInfo.email}</span>
			</a>
			<a
				href={`tel:${contactInfo.phone.replace(/\s/g, '')}`}
				class="flex items-center gap-2 text-xs font-medium tracking-wide transition-colors hover:text-gray-300"
			>
				<svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
				</svg>
				<span class="hidden sm:inline">{contactInfo.phone}</span>
			</a>
		</div>
		<div class="flex items-center">
			<a
				href="https://wa.me/221772960776"
				target="_blank"
				rel="noopener noreferrer"
				class="flex items-center gap-2 text-xs font-medium tracking-wide transition-colors hover:text-gray-300"
			>
				<svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor">
					<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
				</svg>
				<span class="hidden sm:inline">WhatsApp</span>
			</a>
		</div>
	</div>

	<!-- Main Navbar -->
	<div class="main-navbar">
		<!-- Logo (Left) -->
		<div class="nav-logo">
			<a href="/" aria-label="Confection Univers — accueil">
				<img 
					src="/images/logo.png"
					alt="Confection Univers"
					class="h-16 w-auto max-w-[min(100%,18rem)] object-contain object-left sm:h-18 sm:max-w-[20rem] md:h-20 md:max-w-[22rem] lg:h-22 lg:max-w-[24rem]"
					width="200"
					height="76"
					loading="eager"
					decoding="async"
				/>
			</a>
		</div>

		<!-- Navigation Links (Center) -->
		<nav class="nav-links">
			{
				NAV_LINKS.map((link) => (
					<a href={link.href} class="text-[13px] font-bold uppercase tracking-[0.15em] text-gray-800 transition-colors duration-200 hover:text-gray-900">
						{link.label}
					</a>
				))
			}
		</nav>

		<!-- Quote Button (Right) -->
		<div class="nav-actions">
			<button
				type="button"
				id="nav-menu-btn"
				class="p-2 text-gray-800 transition-colors duration-200 hover:text-gray-900 lg:hidden"
				aria-expanded="false"
				aria-controls="nav-mobile-panel"
			>
				<span class="sr-only">Menu</span>
				<svg id="nav-icon-open" class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"
					></path>
				</svg>
				<svg id="nav-icon-close" class="hidden h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"
					></path>
				</svg>
			</button>

			<a
				href="/contact"
				class="hidden items-center gap-2 rounded-lg border-2 border-gray-900 bg-gray-900 px-8 py-3 text-[12px] font-bold uppercase tracking-widest text-white transition-all duration-200 hover:bg-gray-800 hover:border-gray-800 md:flex"
			>
				Demander un devis
				<svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"></path>
				</svg>
			</a>
		</div>
	</div>

	<!-- Mobile Panel -->
	<div id="nav-mobile-panel" class="nav-mobile-panel overflow-hidden border-b border-gray-200 bg-white lg:hidden">
		<div class="flex flex-col gap-6 px-6 py-10">
			{
				NAV_LINKS.map((link) => (
					<a href={link.href} class="font-display text-2xl font-bold uppercase text-gray-900 transition-colors duration-200 hover:text-gray-700">
						{link.label}
					</a>
				))
			}
			<a
				href="/contact"
				class="mt-4 rounded-lg bg-gray-900 py-4 text-center text-sm font-bold uppercase tracking-widest text-white transition-all duration-200 hover:bg-gray-800"
			>
				Demander un devis
			</a>
		</div>
	</div>
</header>

<script>
	const btn = document.getElementById('nav-menu-btn');
	const panel = document.getElementById('nav-mobile-panel');
	const iconOpen = document.getElementById('nav-icon-open');
	const iconClose = document.getElementById('nav-icon-close');

	btn?.addEventListener('click', () => {
		const open = btn.getAttribute('aria-expanded') === 'true';
		const next = !open;
		btn.setAttribute('aria-expanded', next ? 'true' : 'false');
		panel?.classList.toggle('is-open', next);
		iconOpen?.classList.toggle('hidden', next);
		iconClose?.classList.toggle('hidden', !next);
	});
</script>

<style>
	.top-bar {
		display: flex;
		justify-content: space-between;
		align-items: center;
		background-color: #0b0f19;
		color: white;
		padding: 8px 4%;
		width: 100%;
	}

	.main-navbar {
		display: flex;
		justify-content: space-between;
		align-items: center;
		background-color: white;
		padding: 15px 4%;
		width: 100%;
		box-shadow: 0 4px 10px rgba(0,0,0,0.05);
	}

	.nav-links {
		display: flex;
		gap: 24px;
		align-items: center;
	}

	.nav-links a {
		position: relative;
	}

	.nav-mobile-panel {
		max-height: 0;
		transition: max-height 0.45s ease;
	}

	.nav-mobile-panel.is-open {
		max-height: 28rem;
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	/* Hide nav-links on mobile, show on desktop */
	@media (max-width: 1023px) {
		.nav-links {
			display: none;
		}
	}

	@media (min-width: 1024px) {
		.nav-links {
			display: flex;
		}
	}
</style>
