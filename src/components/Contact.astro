---
/**
 * Section contact premium — ajustez `contact` et `formAction` selon votre configuration.
 * Formulaire : par défaut FormSubmit (remplacez l’URL par votre e-mail FormSubmit ou autre endpoint).
 */
const contact = {
	phoneDisplay: '+221 76 787 86 40',
	phoneTel: '+221767878640',
	whatsappDigits: '221767878640',
	email: 'confectionunivers@gmail.com',
	addressLines: ['Zac nguinth', 'Thiès', 'Sénégal'],
};

const addressForMaps = encodeURIComponent(contact.addressLines.join(', '));
const mapsEmbedUrl = `https://maps.google.com/maps?q=${addressForMaps}&z=15&output=embed`;
const whatsappUrl = `https://wa.me/${contact.whatsappDigits}?text=${encodeURIComponent('Bonjour Confection Univers, je souhaite obtenir des informations.')}`;

const formAction = `https://formsubmit.co/${contact.email}`;
const siteBase = import.meta.env.SITE?.replace(/\/$/, '');
const formNext = siteBase ? `${siteBase}/contact?envoye=1` : undefined;
---

<section
	id="contact"
	class="relative scroll-mt-24 border-t border-primary/10 bg-paper py-24 text-ink md:py-32"
	lang="fr"
	aria-labelledby="contact-heading"
>
	<div class="mx-auto max-w-7xl px-6">
		<div class="mx-auto mb-14 max-w-2xl text-center md:mb-16">
			<p class="mb-3 text-[11px] font-semibold uppercase tracking-[0.35em] text-primary md:text-xs">Contact</p>
			<h2 id="contact-heading" class="font-display text-4xl font-semibold tracking-tight md:text-5xl lg:text-6xl">
				Demander un devis
			</h2>
			<p class="mt-4 text-base leading-relaxed text-ink/65 md:text-lg">
				Devis, échantillons ou questions sur nos vêtements : notre équipe répond avec soin et efficacité.
			</p>
		</div>

		<div class="grid gap-12 lg:grid-cols-12 lg:gap-10 xl:gap-14">
			<!-- Coordonnées + carte -->
			<div class="flex flex-col gap-10 lg:col-span-5 xl:col-span-5">
				<ul class="space-y-6">
					<li class="flex gap-4">
						<span
							class="mt-0.5 flex h-11 w-11 shrink-0 items-center justify-center rounded-xl border border-primary/25 bg-background/5 text-primary"
							aria-hidden="true"
						>
							<svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
								/>
							</svg>
						</span>
						<div>
							<p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-ink/45">Téléphone</p>
							<a
								href={`tel:${contact.phoneTel}`}
								class="mt-1 block font-display text-lg font-semibold text-ink transition hover:text-primary"
							>
								{contact.phoneDisplay}
							</a>
						</div>
					</li>

					<li class="flex gap-4">
						<span
							class="mt-0.5 flex h-11 w-11 shrink-0 items-center justify-center rounded-xl border border-primary/25 bg-background/5 text-primary"
							aria-hidden="true"
						>
							<svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
								/>
							</svg>
						</span>
						<div>
							<p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-ink/45">Courriel</p>
							<a
								href={`mailto:${contact.email}`}
								class="mt-1 block break-all font-display text-lg font-semibold text-ink transition hover:text-primary"
							>
								{contact.email}
							</a>
						</div>
					</li>

					<li class="flex gap-4">
						<span
							class="mt-0.5 flex h-11 w-11 shrink-0 items-center justify-center rounded-xl border border-primary/25 bg-background/5 text-primary"
							aria-hidden="true"
						>
							<svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
								<path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
							</svg>
						</span>
						<div>
							<p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-ink/45">Adresse</p>
							<address class="mt-1 not-italic leading-relaxed text-ink/85">
								{contact.addressLines.map((line) => (
									<span class="block font-medium">{line}</span>
								))}
							</address>
							<a
								href={`https://www.google.com/maps/search/?api=1&query=${addressForMaps}`}
								class="mt-3 inline-flex text-sm font-semibold text-primary underline-offset-4 transition hover:underline"
								target="_blank"
								rel="noopener noreferrer"
							>
								Ouvrir dans Google Maps
							</a>
						</div>
					</li>
				</ul>

				<a
					href={whatsappUrl}
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex w-full max-w-md items-center justify-center gap-3 rounded-2xl bg-[#25D366] px-6 py-4 text-sm font-bold uppercase tracking-[0.12em] text-white shadow-lg shadow-emerald-900/15 transition hover:brightness-110 hover:shadow-xl focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#25D366] sm:w-auto sm:px-10"
				>
					<svg class="h-6 w-6 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
						<path
							d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
						/>
					</svg>
					Discuter sur WhatsApp
				</a>

				<div class="overflow-hidden rounded-2xl border border-ink/10 bg-surface/30 shadow-inner ring-1 ring-primary/10 md:rounded-3xl">
					<div class="aspect-[16/11] w-full min-h-[220px] sm:aspect-[16/10] sm:min-h-[260px]">
						<iframe
							title="Confection Univers location on Google Maps"
							class="h-full w-full border-0"
							src={mapsEmbedUrl}
							loading="lazy"
							referrerpolicy="no-referrer-when-downgrade"
							allowfullscreen
						></iframe>
					</div>
				</div>
			</div>

			<!-- Formulaire -->
			<div
				class="rounded-[1.75rem] border border-ink/10 bg-paper p-6 shadow-[0_20px_60px_-24px_rgba(5,10,20,0.12)] md:rounded-3xl md:p-8 lg:col-span-7 xl:col-span-7"
			>
				<h3 class="font-display text-2xl font-semibold text-ink md:text-3xl">Envoyez-nous un message</h3>
				<p class="mt-2 text-sm text-ink/55 md:text-base">
					Réponse habituelle sous 1 à 2 jours ouvrables. Les champs marqués d'une astérisque sont obligatoires.
				</p>

				<form
					class="mt-8 flex flex-col gap-5 md:gap-6"
					action={formAction}
					method="POST"
				>
					<input type="hidden" name="_subject" value="Message depuis confectionunivers.com" />
					{formNext && <input type="hidden" name="_next" value={formNext} />}
					<input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="absolute -left-[9999px] h-0 w-0 opacity-0" aria-hidden="true" />

					<div class="grid gap-5 sm:grid-cols-2">
						<div class="flex flex-col gap-2">
							<label for="contact-name" class="text-xs font-semibold uppercase tracking-wider text-ink/55">
								Nom complet <span class="text-primary">*</span>
							</label>
							<input
								id="contact-name"
								name="name"
								type="text"
								required
								autocomplete="name"
								placeholder="Jean Dupont"
								class="rounded-xl border border-ink/15 bg-paper px-4 py-3.5 text-ink outline-none ring-primary/30 transition placeholder:text-ink/35 focus:border-primary/50 focus:ring-2"
							/>
						</div>
						<div class="flex flex-col gap-2">
							<label for="contact-email" class="text-xs font-semibold uppercase tracking-wider text-ink/55">
								Courriel <span class="text-primary">*</span>
							</label>
							<input
								id="contact-email"
								name="email"
								type="email"
								required
								autocomplete="email"
								placeholder="vous@exemple.com"
								class="rounded-xl border border-ink/15 bg-paper px-4 py-3.5 text-ink outline-none ring-primary/30 transition placeholder:text-ink/35 focus:border-primary/50 focus:ring-2"
							/>
						</div>
					</div>

					<div class="flex flex-col gap-2">
						<label for="contact-phone" class="text-xs font-semibold uppercase tracking-wider text-ink/55">
							Téléphone
						</label>
						<input
							id="contact-phone"
							name="phone"
							type="tel"
							autocomplete="tel"
							placeholder={contact.phoneDisplay}
							class="rounded-xl border border-ink/15 bg-paper px-4 py-3.5 text-ink outline-none ring-primary/30 transition placeholder:text-ink/35 focus:border-primary/50 focus:ring-2"
						/>
					</div>

					<div class="flex flex-col gap-2">
						<label for="contact-clothing-type" class="text-xs font-semibold uppercase tracking-wider text-ink/55">
							Type de vêtement <span class="text-primary">*</span>
						</label>
						<select
							id="contact-clothing-type"
							name="clothing_type"
							required
							class="rounded-xl border border-ink/15 bg-paper px-4 py-3.5 text-ink outline-none ring-primary/30 transition placeholder:text-ink/35 focus:border-primary/50 focus:ring-2"
						>
							<option value="">Sélectionner le type de vêtement</option>
							<option value="graduation-gowns">Toges de graduation</option>
							<option value="school-uniforms">Uniformes scolaires</option>
							<option value="corporate-workwear">Tenues d'entreprise</option>
							<option value="industrial-workwear">Tenues de travail industrielles</option>
							<option value="medical-scrubs">Blouses médicales</option>
							<option value="lab-coats">Blouses de laboratoire</option>
							<option value="healthcare-uniforms">Uniformes de santé</option>
							<option value="custom-manufacturing">Confection personnalisée</option>
							<option value="other">Autre</option>
						</select>
					</div>

					<div class="flex flex-col gap-2">
						<label for="contact-quantity" class="text-xs font-semibold uppercase tracking-wider text-ink/55">
							Quantité <span class="text-primary">*</span>
						</label>
						<input
							id="contact-quantity"
							name="quantity"
							type="number"
							required
							min="1"
							placeholder="Nombre de vêtements"
							class="rounded-xl border border-ink/15 bg-paper px-4 py-3.5 text-ink outline-none ring-primary/30 transition placeholder:text-ink/35 focus:border-primary/50 focus:ring-2"
						/>
					</div>

					<div class="flex flex-col gap-2">
						<label for="contact-customization" class="text-xs font-semibold uppercase tracking-wider text-ink/55">
							Détails de personnalisation
						</label>
						<textarea
							id="contact-customization"
							name="customization"
							rows="3"
							placeholder="Décrivez vos besoins de personnalisation (couleurs, logos, tailles, etc.)"
							class="min-h-[100px] resize-y rounded-xl border border-ink/15 bg-paper px-4 py-3.5 text-ink outline-none ring-primary/30 transition placeholder:text-ink/35 focus:border-primary/50 focus:ring-2"
						></textarea>
					</div>

					<div class="flex flex-col gap-2">
						<label for="contact-message" class="text-xs font-semibold uppercase tracking-wider text-ink/55">
							Message additionnel
						</label>
						<textarea
							id="contact-message"
							name="message"
							rows="4"
							placeholder="Tout autre détail ou question"
							class="min-h-[120px] resize-y rounded-xl border border-ink/15 bg-paper px-4 py-3.5 text-ink outline-none ring-primary/30 transition placeholder:text-ink/35 focus:border-primary/50 focus:ring-2"
						></textarea>
					</div>

					<button
						type="submit"
						class="mt-2 inline-flex min-h-[3.25rem] w-full items-center justify-center rounded-xl bg-ink px-8 py-4 text-[13px] font-semibold uppercase tracking-[0.18em] text-paper transition hover:bg-primary hover:text-background focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary sm:w-auto sm:min-w-[12rem]"
					>
						Envoyer le message
					</button>
				</form>
			</div>
		</div>
	</div>
</section>
