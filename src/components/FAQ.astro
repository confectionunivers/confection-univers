---
const faqItems = [
	{
		question: 'Existe-t-il une quantité minimale de commande (MOQ) ?',
		answer: 'Nous collaborons principalement avec les institutions et entreprises pour des productions en série. Contactez-nous via le formulaire pour étudier la faisabilité selon vos besoins spécifiques.'
	},
	{
		question: 'Quels sont vos délais moyens de confection et de livraison ?',
		answer: 'Nos délais dépendent du volume de la commande. En moyenne, après validation du prototype, la livraison est effectuée sous 2 à 4 semaines partout au Sénégal.'
	},
	{
		question: 'Proposez-vous la personnalisation complète avec nos logos ?',
		answer: 'Absolument. Notre atelier maîtrise les techniques de broderie haute définition, de sérigraphie et de marquage pour apposer fidèlement l\'identité de votre institution sur chaque vêtement.'
	},
	{
		question: 'Livrez-vous en dehors de Dakar et Thiès ?',
		answer: 'Oui, Confection Univers assure une expédition sécurisée et clé en main de vos commandes dans toutes les régions du Sénégal.'
	}
];
---

<section class="relative z-10 py-32 border-0" style="background: #00001C;">
	<!-- Premium Golden Glow -->
	<div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
		<div class="absolute left-[10%] top-[25%] w-[500px] h-[500px] rounded-full" style="background: radial-gradient(ellipse, rgba(250, 204, 107, 0.12) 0%, transparent 70%); filter: blur(100px);"></div>
		<div class="absolute right-[10%] bottom-[25%] w-[400px] h-[400px] rounded-full" style="background: radial-gradient(ellipse, rgba(250, 204, 107, 0.08) 0%, transparent 70%); filter: blur(80px);"></div>
	</div>

	<div class="mx-auto max-w-4xl px-6">
		<div class="mb-16 text-center">
			<div class="reveal-view mb-6 text-[11px] font-semibold uppercase tracking-[0.2em] premium-subtitle" style="color: rgba(250, 204, 107, 0.7);">
				Besoin d'informations ?
			</div>

			<h2
				class="reveal-view font-display text-2xl md:text-3xl font-bold text-[#F9FAFB] text-center tracking-tight"
			>
				Questions <span style="color: #FACC6B;">Fréquentes</span>
			</h2>
		</div>

		<div class="space-y-4">
			{
				faqItems.map((item, index) => (
					<div class="faq-item" data-index={index}>
						<button
							class="faq-question w-full flex items-center justify-between p-6 rounded-[1rem] border border-[#D4AF37]/20 bg-white/5 backdrop-blur-sm transform-gpu transition-all duration-300 will-change-transform hover:border-[#D4AF37]/30 hover:bg-white/10"
							aria-expanded="false"
						>
							<span class="faq-question-text text-left text-base font-medium text-[#F9FAFB] transition-colors duration-300">
								{item.question}
							</span>
							<svg
								class="faq-icon w-5 h-5 text-[#FACC6B] transition-transform duration-300 flex-shrink-0 ml-4"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								viewBox="0 0 24 24"
							>
								<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
							</svg>
						</button>
						<div class="faq-answer overflow-hidden max-h-0 transition-all duration-500 ease-out">
							<div class="p-6 pt-0 text-sm leading-[1.6] text-white/70">
								{item.answer}
							</div>
						</div>
					</div>
				))
			}
		</div>
	</div>
</section>

<script>
	document.querySelectorAll('.faq-question').forEach(button => {
		button.addEventListener('click', () => {
			const faqItem = button.closest('.faq-item') as HTMLElement;
			const answer = faqItem?.querySelector('.faq-answer') as HTMLElement;
			const icon = button.querySelector('.faq-icon') as HTMLElement;
			const questionText = button.querySelector('.faq-question-text') as HTMLElement;
			const isOpen = button.getAttribute('aria-expanded') === 'true';

			// Close all other items
			document.querySelectorAll('.faq-question').forEach(otherButton => {
				if (otherButton !== button) {
					otherButton.setAttribute('aria-expanded', 'false');
					const otherItem = otherButton.closest('.faq-item') as HTMLElement;
					const otherAnswer = otherItem?.querySelector('.faq-answer') as HTMLElement;
					const otherIcon = otherButton.querySelector('.faq-icon') as HTMLElement;
					const otherQuestionText = otherButton.querySelector('.faq-question-text') as HTMLElement;
					
					if (otherAnswer) otherAnswer.style.maxHeight = '0';
					if (otherIcon) otherIcon.style.transform = 'rotate(0deg)';
					if (otherQuestionText) otherQuestionText.style.color = '#F9FAFB';
				}
			});

			// Toggle current item
			button.setAttribute('aria-expanded', (!isOpen).toString());
			if (!isOpen && answer && icon && questionText) {
				answer.style.maxHeight = answer.scrollHeight + 'px';
				icon.style.transform = 'rotate(180deg)';
				questionText.style.color = '#FACC6B';
			} else if (answer && icon && questionText) {
				answer.style.maxHeight = '0';
				icon.style.transform = 'rotate(0deg)';
				questionText.style.color = '#F9FAFB';
			}
		});
	});
</script>

<style>
	.premium-subtitle {
		animation: fadeInUp 0.8s ease-out forwards;
	}

	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.reveal-view {
		opacity: 0;
		animation: fadeInUp 0.8s ease-out forwards;
	}

	.reveal-view:nth-child(1) {
		animation-delay: 0.1s;
	}

	.reveal-view:nth-child(2) {
		animation-delay: 0.2s;
	}
</style>
