---
const textileFeatures = [
	{
		icon: 'shield',
		title: 'Blouses Médicales',
		subtitle: 'Technologie Anti-Bactérienne',
		description: 'Tissu innovant certifié anti-fluide et anti-bactérien. Offre une barrière de protection maximale, une haute respirabilité et une résistance extrême aux lavages industriels à haute température.'
	},
	{
		icon: 'wrench',
		title: 'Tenues de Travail',
		subtitle: 'Ultra-Résistance Normée',
		description: 'Textile de qualité supérieure anti-déchirure avec coutures triples renforcées. Conçu pour endurer les environnements industriels et les conditions de travail les plus exigeantes.'
	},
	{
		icon: 'star',
		title: 'Uniformes & Toges',
		subtitle: 'Confort & Durabilité Or',
		description: 'Fibres premium infroissables sélectionnées pour le climat local. Teinture haute durabilité qui ne déteint pas, garantissant un éclat impeccable année après année.'
	}
];

const icons = {
	shield: `<svg class="h-8 w-8" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /></svg>`,
	wrench: `<svg class="h-8 w-8" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`,
	star: `<svg class="h-8 w-8" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" /></svg>`
};
---

<section class="relative z-10 py-32 border-0" style="background: linear-gradient(180deg, #00002a 0%, #00001C 100%);">
	<!-- Premium Golden Glow -->
	<div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
		<div class="absolute left-[10%] top-[25%] w-[500px] h-[500px] rounded-full" style="background: radial-gradient(ellipse, rgba(250, 204, 107, 0.12) 0%, transparent 70%); filter: blur(100px);"></div>
		<div class="absolute right-[10%] bottom-[25%] w-[400px] h-[400px] rounded-full" style="background: radial-gradient(ellipse, rgba(250, 204, 107, 0.08) 0%, transparent 70%); filter: blur(80px);"></div>
	</div>

	<div class="mx-auto max-w-7xl px-6">
		<div class="mb-24 text-center">
			<div class="reveal-view mb-6 text-[11px] font-semibold uppercase tracking-[0.2em] premium-subtitle" style="color: rgba(250, 204, 107, 0.7);">
				Excellence technique
			</div>

			<h2
				class="reveal-view font-display text-2xl md:text-3xl font-bold text-[#F9FAFB] text-center tracking-tight"
			>
				Ingénierie & <span style="color: #FACC6B;">Haute Qualité Textile</span>
			</h2>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
			{
				textileFeatures.map((feature, index) => (
					<div
						class="group relative overflow-hidden rounded-[1.5rem] border border-[rgba(250,204,107,0.25)] bg-white/5 backdrop-blur-sm p-6 md:p-8 transform-gpu transition-all duration-500 ease-out will-change-transform hover:-translate-y-2 hover:shadow-[0_20px_50px_rgba(212,175,55,0.15)] hover:border-[rgba(250,204,107,0.4)]"
					>
						<div class="relative z-20">
							<!-- Icon -->
							<div class="mb-6 flex items-center justify-center w-16 h-16 rounded-full bg-[rgba(250,204,107,0.1)] border border-[rgba(250,204,107,0.2)]" style="color: #FACC6B;">
								<div set:html={icons[feature.icon]} />
							</div>

							<h3 class="mb-2 font-display text-xl font-bold text-[#F9FAFB] tracking-tight">
								{feature.title}
							</h3>

							<div class="mb-4 text-sm font-semibold uppercase tracking-wider" style="color: #FACC6B;">
								{feature.subtitle}
							</div>

							<p class="text-sm font-normal leading-[1.6] text-white/70">
								{feature.description}
							</p>
						</div>

						<!-- Decorative Glow -->
						<div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-transparent via-transparent to-[rgba(212,175,55,0.05)] opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
					</div>
				))
			}
		</div>
	</div>
</section>

<style>
	.premium-subtitle {
		animation: fadeInUp 0.8s ease-out forwards;
	}

	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.reveal-view {
		opacity: 0;
		animation: fadeInUp 0.8s ease-out forwards;
	}

	.reveal-view:nth-child(1) {
		animation-delay: 0.1s;
	}

	.reveal-view:nth-child(2) {
		animation-delay: 0.2s;
	}
</style>
