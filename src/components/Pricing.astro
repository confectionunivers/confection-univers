---
const FEATURES = [
	'Capacité de production en gros',
	'Sélection de tissus personnalisés',
	'Couverture de toutes les tailles',
	'Assurance qualité',
	'Calendriers de livraison flexibles',
	'Développement d\'échantillons',
	'Personnalisation de marque',
	'Support post-production',
];
---

<section class="relative z-10 rounded-[4rem] bg-paper py-32 text-ink shadow-[0_20px_80px_-20px_rgba(5,10,20,0.1)]">
	<div class="mx-auto max-w-7xl px-6">
		<div class="grid gap-8 lg:grid-cols-2">
			<div
				class="reveal-view relative flex min-h-[600px] flex-col justify-between overflow-hidden rounded-[3.5rem] bg-ink p-16 text-paper"
			>
				<img
					src="/images/hero-tenues-travail-sport.jpg"
					class="absolute inset-0 h-full w-full object-cover opacity-25"
					alt="Installation de production"
				/>
				<div class="relative z-10">
					<div class="mb-10 text-sm font-black uppercase tracking-[0.3em] text-primary">Devis personnalisés disponibles</div>
					<h2 class="font-display text-5xl font-bold leading-[0.9] tracking-tighter text-paper lg:text-7xl">
						Production en gros pour les institutions et entreprises de toutes tailles.
					</h2>
				</div>

				<div class="relative z-10 pt-20">
					<div class="mb-4 flex items-center gap-3 text-xs font-black uppercase tracking-[0.2em] text-primary">
						<span class="h-2 w-2 animate-pulse rounded-full bg-primary" />
						Capacité de production disponible
					</div>
					<h3 class="font-display text-4xl font-bold uppercase tracking-tighter text-paper">Demander un devis aujourd'hui</h3>
				</div>
			</div>

			<div
				class="reveal-view flex flex-col justify-between rounded-[3.5rem] border border-primary/15 bg-paper p-16 ring-1 ring-ink/5"
			>
				<div>
					<div class="mb-10 flex items-start justify-between">
						<div>
							<h3 class="mb-2 font-display text-4xl font-bold uppercase tracking-tighter text-ink">Production en gros</h3>
							<p class="font-medium text-ink/55">Parfait pour les institutions et les commandes importantes.</p>
						</div>
						<div class="rounded-full border border-primary/25 bg-primary/10 px-4 py-1 text-[10px] font-black uppercase tracking-widest text-primary">
							Popular
						</div>
					</div>

					<div class="mb-12 font-display text-7xl font-bold tracking-tighter text-ink lg:text-8xl">
						Prix personnalisé
					</div>

					<ul class="mb-16 grid grid-cols-1 gap-x-12 gap-y-6 md:grid-cols-2">
						{
							FEATURES.map((f) => (
								<li class="flex items-center gap-3 text-sm font-bold uppercase tracking-tight text-ink">
									<div class="flex h-5 w-5 items-center justify-center rounded-full bg-primary text-background">
										<svg class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="4" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
										</svg>
									</div>
									{f}
								</li>
							))
						}
					</ul>
				</div>

				<button
					type="button"
					class="w-full rounded-2xl border border-primary/25 bg-ink py-6 text-[12px] font-black uppercase tracking-[0.2em] text-paper shadow-xl transition hover:bg-primary hover:text-background"
				>
					Demander un devis
				</button>
			</div>
		</div>
	</div>
</section>
