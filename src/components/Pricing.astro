---
const FEATURES = [
	'Capacité de production en gros',
	'Sélection de tissus personnalisés',
	'Couverture de toutes les tailles',
	'Assurance qualité',
	'Calendriers de livraison flexibles',
	'Développement d\'échantillons',
	'Personnalisation de marque',
	'Support post-production',
];
---

<section class="relative z-10 rounded-[4rem] bg-paper py-32 text-ink border-0">
	<div class="mx-auto max-w-7xl px-6">
		<div class="grid gap-8 lg:grid-cols-2">
			<div
				class="reveal-view relative flex min-h-[500px] flex-col justify-between overflow-hidden rounded-[3.5rem] bg-ink p-16 text-paper"
			>
				<img
					src="/images/production-atelier.jpg"
					class="absolute inset-0 h-full w-full object-cover opacity-25"
					alt="Installation de production"
				/>
				<div class="relative z-10">
					<div class="mb-6 text-[11px] font-semibold uppercase tracking-[0.2em] text-primary">Devis personnalisés disponibles</div>
					<h2 class="font-display text-2xl font-bold leading-[1.1] tracking-tight text-paper lg:text-3xl">
						Production en gros pour les institutions et entreprises de toutes tailles.
					</h2>
				</div>

				<div class="relative z-10 pt-12">
					<div class="mb-3 flex items-center gap-3 text-[11px] font-semibold uppercase tracking-[0.2em] text-primary">
						<span class="h-2 w-2 animate-pulse rounded-full bg-primary" />
						Capacité de production disponible
					</div>
					<h3 class="font-display text-xl font-bold uppercase tracking-tight text-paper">Demander un devis aujourd'hui</h3>
				</div>
			</div>

			<div
				class="reveal-view flex flex-col justify-between rounded-[3.5rem] border border-primary/15 bg-paper p-16 ring-1 ring-ink/5"
			>
				<div>
					<div class="mb-8 flex items-start justify-between">
						<div>
							<h3 class="mb-2 font-display text-2xl font-bold uppercase tracking-tight text-ink lg:text-3xl">Production en gros</h3>
							<p class="text-sm font-normal text-ink/55">Parfait pour les institutions et les commandes importantes.</p>
						</div>
						<div class="rounded-full border border-primary/25 bg-primary/10 px-4 py-1 text-[10px] font-semibold uppercase tracking-widest text-primary">
							Popular
						</div>
					</div>

					<div class="mb-10 font-display text-4xl font-bold tracking-tight text-ink lg:text-5xl">
						Prix personnalisé
					</div>

					<ul class="mb-12 grid grid-cols-1 gap-x-8 gap-y-4 md:grid-cols-2">
						{
							FEATURES.map((f) => (
								<li class="flex items-center gap-3 text-sm font-semibold tracking-tight text-ink">
									<div class="flex h-5 w-5 items-center justify-center rounded-full bg-primary text-background">
										<svg class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="4" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
										</svg>
									</div>
									{f}
								</li>
							))
						}
					</ul>
				</div>

				<button
					type="button"
					class="group relative inline-flex w-full min-h-[3.25rem] items-center justify-center overflow-hidden rounded-full px-8 py-3.5 text-center text-[13px] font-semibold uppercase tracking-[0.18em] text-background transition-all duration-500"
					style="background: linear-gradient(135deg, #FACC6B 0%, #F59E0B 50%, #D97706 100%); box-shadow: inset 0 1px 0 rgba(255,255,255,0.15), 0 18px 40px rgba(0, 0, 0, 0.50); border: 1px solid rgba(161, 98, 7, 0.7);"
				>
					<span class="relative z-10 transition-transform duration-300 group-hover:scale-[1.02]">Demander un devis</span>
					<span class="absolute inset-0 rounded-full border-2 border-primary/0 transition-all duration-500 group-hover:border-primary/50 group-hover:shadow-[0_0_30px_rgba(198,161,95,0.4)]"></span>
				</button>
			</div>
		</div>
	</div>
</section>
