---
const LOGOS = ['CONFECTION DE TOGES', 'UNIFORMES SCOLAIRES', 'TENUES DE TRAVAIL', 'ÉQUIPEMENTS SPORTIFS', 'BLOUSES MÉDICALES', 'QUALITÉ PREMIUM', 'PRODUCTION EN GROS'];
---

<section class="overflow-hidden bg-background py-20 border-0 relative">
	<div class="marquee-wrapper flex w-max whitespace-nowrap">
		{
			[0, 1, 2, 3].map(() => (
				<div class="flex items-center gap-32 px-10">
					{LOGOS.map((logo) => (
						<div class="flex items-center gap-32">
							<span class="cursor-default font-display text-3xl font-black uppercase tracking-tight text-foreground/12 transition-colors hover:text-primary lg:text-5xl">
								{logo}
							</span>
							<div class="h-2 w-2 rounded-full bg-primary/80" />
						</div>
					))}
				</div>
			))
		}
	</div>
</section>

<style>
	.marquee-wrapper {
		animation: marquee-scroll 30s linear infinite;
	}

	.marquee-wrapper:hover {
		animation-play-state: paused;
	}

	@keyframes marquee-scroll {
		0% {
			transform: translateX(0);
		}
		100% {
			transform: translateX(-50%);
		}
	}
</style>
