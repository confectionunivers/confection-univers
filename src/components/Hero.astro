---
/**
 * Visuels hero : placez vos fichiers dans public/images/
 * (ajustez les noms ci-dessous si besoin).
 */
const heroImages = {
	graduation: '/images/hero-toges-graduation.jpg',
	uniformes: '/images/hero-uniformes.jpg',
	tenues: '/images/hero-tenues-travail-sport.jpg',
};

const galleryItems = [
	{ image: '/images/gallery1.jpg', label: 'Toges de graduation' },
	{ image: '/images/gallery2.jpg', label: 'Uniformes scolaires' },
	{ image: '/images/gallery3.jpg', label: 'Tenues d\'entreprise' },
];

---

<section
	id="hero"
	class="hero-section relative flex min-h-screen flex-col justify-center overflow-hidden pb-20 pt-36 md:pt-40"
	aria-label="Accueil"
	lang="fr"
>
	<!-- 3D Background Layers -->
	<div class="pointer-events-none absolute inset-0 -z-30 bg-background"></div>
	
	<!-- Cinematic Lighting Gradient -->
	<div
		class="pointer-events-none absolute inset-0 -z-20 bg-[radial-gradient(ellipse_85%_60%_at_100%_0%,rgba(198,161,95,0.14),transparent_55%),radial-gradient(ellipse_70%_50%_at_0%_100%,rgba(0,0,42,0.08),transparent_50%)]"
	></div>
	
	<!-- Deep Blue Overlay with Gold Accents -->
	<div
		class="pointer-events-none absolute inset-0 -z-20 bg-gradient-to-b from-background/80 via-transparent to-background"
	></div>
	
	<!-- Floating Geometric Shapes (3D Parallax) -->
	<div class="floating-shapes pointer-events-none absolute inset-0 -z-10 overflow-hidden">
		<div class="shape shape-1 absolute left-[10%] top-[20%] w-32 h-32 rounded-full border border-primary/20 bg-primary/5 blur-2xl"></div>
		<div class="shape shape-2 absolute right-[15%] top-[30%] w-48 h-48 rounded-full border border-primary/15 bg-primary/5 blur-3xl"></div>
		<div class="shape shape-3 absolute left-[20%] bottom-[25%] w-24 h-24 rounded-lg border border-primary/10 bg-primary/5 blur-xl rotate-45"></div>
		<div class="shape shape-4 absolute right-[25%] bottom-[35%] w-36 h-36 rounded-full border border-primary/10 bg-primary/5 blur-2xl"></div>
		<div class="shape shape-5 absolute left-[50%] top-[10%] w-16 h-16 rounded-full border border-primary/15 bg-primary/5 blur-lg"></div>
	</div>
	
	<!-- Bottom Gradient Fade -->
	<div
		class="pointer-events-none absolute bottom-0 left-1/2 -z-10 h-[45vh] w-[120%] -translate-x-1/2 bg-gradient-to-t from-background to-transparent"
	></div>

	<!-- Main Content -->
	<div
		class="hero-content mx-auto grid w-full max-w-7xl items-center gap-12 px-6 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)] lg:gap-16 xl:gap-20"
	>
		<!-- Left Column: Text Content -->
		<div class="flex flex-col justify-center">
			<p
				class="hero-reveal mb-5 text-[11px] font-semibold uppercase tracking-[0.38em] text-primary md:text-xs"
				style="--hero-d: 0ms"
			>
				Confection de vêtements professionnels · Sénégal
			</p>

			<h1
				class="hero-reveal font-display text-[clamp(2.5rem,6vw,4.75rem)] font-semibold leading-[1.05] tracking-tight text-foreground md:leading-[1.02]"
				style="--hero-d: 80ms"
			>
				<span class="block text-foreground">Confection</span>
				<span
					class="mt-1 block bg-gradient-to-r from-primary via-primary-light to-primary bg-clip-text text-transparent"
				>
					Univers
				</span>
			</h1>

			<p
				class="hero-reveal mt-8 max-w-xl text-base font-normal leading-relaxed text-foreground/72 md:text-lg md:leading-relaxed"
				style="--hero-d: 160ms"
			>
				Vêtements de qualité supérieure fabriqués avec précision. Designs personnalisés adaptés à vos spécifications. Production en gros fiable pour les institutions et entreprises de toutes tailles.
			</p>

			<div class="hero-reveal mt-10 flex flex-col gap-4 sm:flex-row sm:flex-wrap sm:items-center" style="--hero-d: 240ms">
				<a
					href="/contact"
					class="cta-button-primary group relative inline-flex min-h-[3.25rem] items-center justify-center overflow-hidden rounded-full bg-primary px-8 py-3.5 text-center text-[13px] font-semibold uppercase tracking-[0.18em] text-background transition-all duration-500"
				>
					<span class="cta-button-bg absolute inset-0 bg-gradient-to-r from-primary via-primary-light to-primary opacity-0 transition-opacity duration-500 group-hover:opacity-100"></span>
					<span class="relative z-10 transition-transform duration-300 group-hover:scale-105">Demander un devis</span>
					<span class="cta-button-glow absolute inset-0 rounded-full border-2 border-primary/0 transition-all duration-500 group-hover:border-primary/50 group-hover:shadow-[0_0_30px_rgba(198,161,95,0.4)]"></span>
				</a>
				<a
					href="/products"
					class="cta-button-secondary group relative inline-flex min-h-[3.25rem] items-center justify-center rounded-full border-2 border-primary/45 bg-transparent px-8 py-3.5 text-center text-[13px] font-semibold uppercase tracking-[0.18em] text-foreground transition-all duration-400"
				>
					<span class="relative z-10 transition-all duration-300 group-hover:text-primary group-hover:scale-105">Voir nos produits</span>
					<span class="cta-button-glow absolute inset-0 rounded-full border-2 border-primary/0 transition-all duration-400 group-hover:border-primary group-hover:shadow-[0_0_20px_rgba(198,161,95,0.3)]"></span>
				</a>
			</div>

			<div
				class="hero-reveal mt-14 flex flex-wrap items-center gap-x-10 gap-y-3 border-t border-primary/15 pt-10 text-sm text-foreground/50"
				style="--hero-d: 320ms"
			>
				<span class="font-medium text-foreground/65">Uniformes sur mesure</span>
				<span class="hidden h-1 w-1 rounded-full bg-primary/50 sm:inline" aria-hidden="true"></span>
				<span class="font-medium text-foreground/65">Qualité premium</span>
				<span class="hidden h-1 w-1 rounded-full bg-primary/50 sm:inline" aria-hidden="true"></span>
				<span class="font-medium text-foreground/65">Production en gros</span>
			</div>
		</div>

		<!-- Right Column: 3D Image Gallery -->
		<div class="relative mx-auto w-full max-w-lg lg:mx-0 lg:max-w-none">
			<div
				class="hero-reveal hero-3d-container grid gap-3 sm:gap-4 md:min-h-[min(560px,68vh)] md:grid-cols-[1.12fr_0.88fr] md:grid-rows-2 md:gap-5 perspective-1000"
				style="--hero-d: 100ms"
			>
				<figure
					class="hero-figure-3d group relative col-span-1 overflow-hidden rounded-[1.75rem] border border-primary/20 shadow-[0_24px_80px_-24px_rgba(0,0,0,0.55)] md:row-span-2 md:min-h-[280px] transform-style-3d"
					data-tilt
				>
					<img
						src={heroImages.graduation}
						alt="Professional graduation gowns manufactured with precision and quality"
						class="hero-img-3d h-full min-h-[240px] w-full object-cover transition-transform duration-[1.1s] ease-out will-change-transform md:min-h-full"
						width="800"
						height="1000"
						loading="eager"
						decoding="async"
						fetchpriority="high"
					/>
					<div
						class="pointer-events-none absolute inset-0 bg-gradient-to-t from-background/50 via-transparent to-transparent md:opacity-100"
					></div>
					<!-- 3D Lighting Overlay -->
					<div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-transparent via-transparent to-primary/10 opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
				</figure>

				<figure
					class="hero-figure-3d group relative overflow-hidden rounded-2xl border border-primary/15 shadow-lg md:min-h-0 transform-style-3d"
					data-tilt
				>
					<img
						src={heroImages.uniformes}
						alt="Custom school uniforms manufactured for educational institutions"
						class="hero-img-3d h-full min-h-[150px] w-full object-cover transition-transform duration-[1.1s] ease-out will-change-transform md:min-h-[calc(50%-0.625rem)]"
						width="600"
						height="400"
						loading="eager"
						decoding="async"
					/>
					<div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-background/20 to-transparent"></div>
					<div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-transparent via-transparent to-primary/10 opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
				</figure>

				<figure
					class="hero-figure-3d group relative overflow-hidden rounded-2xl border border-primary/15 shadow-lg md:min-h-0 transform-style-3d"
					data-tilt
				>
					<img
						src={heroImages.tenues}
						alt="Workwear uniforms, medical scrubs and lab coats for professional environments"
						class="hero-img-3d h-full min-h-[150px] w-full object-cover transition-transform duration-[1.1s] ease-out will-change-transform md:min-h-[calc(50%-0.625rem)]"
						width="600"
						height="400"
						loading="lazy"
						decoding="async"
					/>
					<div class="pointer-events-none absolute inset-0 bg-gradient-to-tl from-background/25 to-transparent"></div>
					<div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-transparent via-transparent to-primary/10 opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
				</figure>
			</div>

			<!-- Decorative Circle -->
			<div
				class="pointer-events-none absolute -right-4 top-1/2 hidden h-48 w-48 -translate-y-1/2 rounded-full border border-primary/10 lg:block xl:-right-8"
				aria-hidden="true"
			></div>
		</div>
	</div>

	<!-- Scroll Indicator -->
	<div class="scroll-indicator absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-0 animate-fade-in-up" style="animation-delay: 1.5s;">
		<span class="text-[10px] font-semibold uppercase tracking-[0.2em] text-foreground/40">Scroll</span>
		<div class="scroll-mouse relative h-12 w-7 rounded-full border-2 border-foreground/20">
			<div class="scroll-wheel absolute left-1/2 top-2 h-2 w-1 -translate-x-1/2 rounded-full bg-foreground/40 animate-scroll"></div>
		</div>
	</div>
</section>

<script>
	// Mobile detection for mouse tracking
	const isMobile = () => {
		return /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent) || 
		       ('ontouchstart' in window) || 
		       (navigator.maxTouchPoints > 0);
	};

	// 3D Tilt Effect for Images
	if (!isMobile()) {
		const tiltElements = document.querySelectorAll('[data-tilt]');
		
		tiltElements.forEach(element => {
			element.addEventListener('mousemove', (e) => {
				const rect = element.getBoundingClientRect();
				const x = e.clientX - rect.left;
				const y = e.clientY - rect.top;
				
				const centerX = rect.width / 2;
				const centerY = rect.height / 2;
				
				const rotateX = ((y - centerY) / centerY) * -8; // Max 8deg rotation
				const rotateY = ((x - centerX) / centerX) * 8;
				
				element.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02)`;
			});
			
			element.addEventListener('mouseleave', () => {
				element.style.transform = 'perspective(1000px) rotateX(0) rotateY(0) scale3d(1, 1, 1)';
			});
		});
	}

	// Mouse Parallax for Floating Shapes
	if (!isMobile()) {
		const shapes = document.querySelectorAll('.shape');
		const heroSection = document.querySelector('.hero-section');
		
		heroSection.addEventListener('mousemove', (e) => {
			const x = (e.clientX / window.innerWidth - 0.5) * 2;
			const y = (e.clientY / window.innerHeight - 0.5) * 2;
			
			shapes.forEach((shape, index) => {
				const speed = (index + 1) * 15;
				const translateX = x * speed;
				const translateY = y * speed;
				
				shape.style.transform = `translate(${translateX}px, ${translateY}px)`;
			});
		});
	}
</script>

<style>
	/* 3D Perspective Container */
	.perspective-1000 {
		perspective: 1000px;
	}

	.transform-style-3d {
		transform-style: preserve-3d;
	}

	/* Floating Shapes Animation */
	@keyframes float {
		0%, 100% {
			transform: translateY(0) translateX(0);
		}
		50% {
			transform: translateY(-20px) translateX(10px);
		}
	}

	.shape {
		animation: float 6s ease-in-out infinite;
	}

	.shape-1 {
		animation-delay: 0s;
	}

	.shape-2 {
		animation-delay: 1s;
	}

	.shape-3 {
		animation-delay: 2s;
	}

	.shape-4 {
		animation-delay: 3s;
	}

	.shape-5 {
		animation-delay: 4s;
	}

	/* CTA Button Premium Effects */
	.cta-button-primary {
		position: relative;
		overflow: hidden;
		box-shadow: 0 8px 32px -8px rgba(198, 161, 95, 0.45);
		transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.cta-button-primary:hover {
		box-shadow: 0 12px 40px -6px rgba(198, 161, 95, 0.55), 0 0 30px rgba(198, 161, 95, 0.3);
		transform: translateY(-2px) scale(1.02);
	}

	.cta-button-secondary:hover {
		transform: translateY(-2px) scale(1.02);
		box-shadow: 0 8px 24px -8px rgba(198, 161, 95, 0.3);
	}

	.cta-button-glow {
		pointer-events: none;
	}

	/* Scroll Indicator Animation */
	@keyframes scroll {
		0% {
			opacity: 1;
			transform: translateY(0);
		}
		100% {
			opacity: 0;
			transform: translateY(12px);
		}
	}

	.animate-scroll {
		animation: scroll 2s ease-in-out infinite;
	}

	@keyframes fade-in-up {
		from {
			opacity: 0;
			transform: translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.animate-fade-in-up {
		animation: fade-in-up 0.8s ease-out forwards;
	}

	/* Hero Reveal Animations */
	@keyframes hero-reveal-up {
		from {
			opacity: 0;
			transform: translateY(1.75rem);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes hero-panel-in {
		from {
			opacity: 0;
			transform: translateY(1.35rem) scale(0.99);
		}
		to {
			opacity: 1;
			transform: translateY(0) scale(1);
		}
	}

	@keyframes hero-img-in {
		from {
			opacity: 0;
			transform: scale(1.05) rotateX(5deg);
		}
		to {
			opacity: 1;
			transform: scale(1) rotateX(0);
		}
	}

	@media (prefers-reduced-motion: no-preference) {
		.hero-reveal {
			opacity: 0;
			animation: hero-reveal-up 1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
			animation-delay: var(--hero-d, 0ms);
		}

		.hero-reveal.grid {
			animation-name: hero-panel-in;
			animation-duration: 1.1s;
		}

		.hero-figure-3d .hero-img-3d {
			animation: hero-img-in 1.25s cubic-bezier(0.22, 1, 0.36, 1) both;
		}

		.hero-figure-3d:nth-child(1) .hero-img-3d {
			animation-delay: 0.18s;
		}
		.hero-figure-3d:nth-child(2) .hero-img-3d {
			animation-delay: 0.32s;
		}
		.hero-figure-3d:nth-child(3) .hero-img-3d {
			animation-delay: 0.42s;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.hero-reveal {
			opacity: 1;
			animation: none;
		}
		.hero-figure-3d .hero-img-3d {
			animation: none;
			opacity: 1;
		}
		.shape {
			animation: none;
		}
		.scroll-indicator {
			display: none;
		}
	}

	/* Mobile Optimization */
	@media (max-width: 1023px) {
		.floating-shapes {
			display: none;
		}
		.hero-figure-3d {
			transform: none !important;
		}
	}
</style>
