---
/**
 * Visuels hero : placez vos fichiers dans public/images/
 * (ajustez les noms ci-dessous si besoin).
 */
const heroImages = {
	graduation: '/images/hero-toges-graduation.jpg',
	uniformes: '/images/hero-uniformes.jpg',
	tenues: '/images/hero-tenues-travail-sport.jpg',
};

const galleryItems = [
	{ image: '/images/gallery1.jpg', label: 'Toges de graduation' },
	{ image: '/images/gallery2.jpg', label: 'Uniformes scolaires' },
	{ image: '/images/gallery3.jpg', label: 'Tenues d\'entreprise' },
];

---

<section
	id="hero"
	class="hero-section relative flex min-h-screen flex-col justify-center overflow-hidden pb-0 pt-20 md:pt-24 border-0 outline-none mb-[-1px]"
	aria-label="Accueil"
	lang="fr"
	style="border: none !important; outline: none !important; box-shadow: none !important; background: linear-gradient(135deg, #050816 0%, #0b1024 60%, #020617 100%);"
>
	<!-- Grain Texture Overlay -->
	<div class="pointer-events-none absolute inset-0 -z-10 opacity-[0.05]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.65%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E');"></div>
	
	<!-- Premium Golden Glow Behind Images -->
	<div class="pointer-events-none absolute right-[5%] top-[30%] -z-10 w-[600px] h-[500px] rounded-full" style="background: radial-gradient(ellipse, rgba(250, 204, 107, 0.2) 0%, transparent 70%); filter: blur(80px);"></div>
	
	<!-- Mesh Gradients & Glow Effects -->
	<div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
		<!-- Primary Glow -->
		<div class="absolute left-[5%] top-[10%] w-[500px] h-[500px] rounded-full bg-primary/20 blur-[120px] animate-pulse"></div>
		<!-- Secondary Glow -->
		<div class="absolute right-[10%] bottom-[20%] w-[400px] h-[400px] rounded-full bg-primary-light/15 blur-[100px] animate-pulse" style="animation-delay: 1s;"></div>
		<!-- Accent Glow -->
		<div class="absolute left-[50%] top-[50%] w-[300px] h-[300px] rounded-full bg-primary/10 blur-[80px] animate-pulse" style="animation-delay: 2s;"></div>
		<!-- Mesh Gradient Overlay -->
		<div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-primary-light/5"></div>
	</div>

	<!-- Animated Floating Shapes -->
	<div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
		<div class="floating-shape-1 absolute left-[10%] top-[20%] w-20 h-20 border border-primary/30 rounded-full opacity-20"></div>
		<div class="floating-shape-2 absolute right-[15%] top-[40%] w-16 h-16 border border-primary-light/30 rounded-lg opacity-20"></div>
		<div class="floating-shape-3 absolute left-[20%] bottom-[30%] w-24 h-24 border border-primary/30 rounded-full opacity-20"></div>
		<div class="floating-shape-4 absolute right-[25%] bottom-[20%] w-12 h-12 border border-primary-light/30 rounded-lg opacity-20"></div>
	</div>

	<!-- Line Animations -->
	<div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
		<div class="line-1 absolute left-[5%] top-[15%] w-[1px] h-[200px] bg-gradient-to-b from-transparent via-primary/30 to-transparent"></div>
		<div class="line-2 absolute right-[10%] top-[25%] w-[1px] h-[150px] bg-gradient-to-b from-transparent via-primary-light/30 to-transparent"></div>
		<div class="line-3 absolute left-[15%] bottom-[20%] w-[1px] h-[180px] bg-gradient-to-b from-transparent via-primary/30 to-transparent"></div>
		<div class="line-4 absolute right-[20%] bottom-[15%] w-[1px] h-[120px] bg-gradient-to-b from-transparent via-primary-light/30 to-transparent"></div>
	</div>

	<!-- Marquee Text Animation -->
	<div class="absolute bottom-16 left-0 right-0 overflow-hidden pointer-events-none">
		<div class="marquee-container flex whitespace-nowrap">
			<div class="marquee-content flex items-center gap-8 text-primary/40 text-sm uppercase tracking-widest">
				<span>Confection de Toges</span>
				<span class="w-2 h-2 rounded-full bg-primary/40"></span>
				<span>Uniformes Scolaires</span>
				<span class="w-2 h-2 rounded-full bg-primary/40"></span>
				<span>Tenues de Travail</span>
				<span class="w-2 h-2 rounded-full bg-primary/40"></span>
				<span>Équipements Sportifs</span>
				<span class="w-2 h-2 rounded-full bg-primary/40"></span>
				<span>Blouses Médicales</span>
				<span class="w-2 h-2 rounded-full bg-primary/40"></span>
				<span>Confection de Toges</span>
				<span class="w-2 h-2 rounded-full bg-primary/40"></span>
				<span>Uniformes Scolaires</span>
				<span class="w-2 h-2 rounded-full bg-primary/40"></span>
				<span>Tenues de Travail</span>
				<span class="w-2 h-2 rounded-full bg-primary/40"></span>
				<span>Équipements Sportifs</span>
				<span class="w-2 h-2 rounded-full bg-primary/40"></span>
				<span>Blouses Médicales</span>
				<span class="w-2 h-2 rounded-full bg-primary/40"></span>
			</div>
		</div>
	</div>

	<!-- Scroll Down Indicator avec Lottie -->
	<div class="absolute bottom-24 left-1/2 -translate-x-1/2 z-10 pointer-events-none">
		<div class="scroll-down-indicator flex flex-col items-center gap-2">
			<span class="text-primary/60 text-xs uppercase tracking-widest">Scroll</span>
			<div class="scroll-chevron w-6 h-6 text-primary/60 animate-bounce">
				<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
					<path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
				</svg>
			</div>
		</div>
	</div>

	<!-- WhatsApp Floating Button -->
	<a
		href="https://wa.me/221771234567"
		target="_blank"
		rel="noopener noreferrer"
		class="whatsapp-float fixed bottom-8 right-8 z-50 flex items-center justify-center w-14 h-14 bg-[#25D366] rounded-full shadow-lg hover:shadow-xl transition-all duration-300 hover:scale-110 group"
		aria-label="Contactez-nous sur WhatsApp"
	>
		<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24">
			<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
		</svg>
		<div class="whatsapp-pulse-ring absolute inset-0 rounded-full border-2 border-[#25D366] opacity-0 pointer-events-none"></div>
	</a>
	
	<!-- Main Content -->
	<div
		class="hero-content mx-auto grid w-full max-w-7xl items-center gap-12 px-6 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:gap-16 xl:gap-20 relative"
	>
		<!-- Sewing-inspired vertical divider line -->
		<div class="hidden lg:block absolute left-[45%] top-[20%] bottom-[20%] w-px bg-gradient-to-b from-transparent via-[rgba(148,163,184,0.25)] to-transparent -translate-x-1/2"></div>

		<!-- Sewing pattern markers (subtle circles) -->
		<div class="hidden lg:block absolute left-[40%] top-[25%] w-2 h-2 rounded-full border border-[rgba(148,163,184,0.15)] -translate-x-1/2" aria-hidden="true"></div>
		<div class="hidden lg:block absolute left-[40%] top-[50%] w-2 h-2 rounded-full border border-[rgba(148,163,184,0.15)] -translate-x-1/2" aria-hidden="true"></div>
		<div class="hidden lg:block absolute left-[40%] top-[75%] w-2 h-2 rounded-full border border-[rgba(148,163,184,0.15)] -translate-x-1/2" aria-hidden="true"></div>

		<!-- Left Column: Text Content -->
		<div class="hero-text-block flex flex-col justify-center lg:w-full">
			<p
				id="hero-subtitle"
				class="mb-5 text-[11px] font-semibold uppercase tracking-[0.2em] text-[rgba(250,204,107,0.7)] md:text-xs"
			>
				CONFECTION DE VÊTEMENTS PROFESSIONNELS - SÉNÉGAL
			</p>

			<h1
				id="hero-title"
				class="font-display text-[clamp(2.5rem,6vw,4.75rem)] font-semibold leading-[1.05] tracking-tight md:leading-[1.02]"
			>
				<span class="block text-[#F9FAFB]">Confection</span>
				<span
					class="mt-1 block font-bold animated-gradient-text"
				>
					Univers
				</span>
			</h1>

			<p
				id="hero-description"
				class="mt-8 max-w-xl text-base font-normal leading-[1.6] text-foreground/72 md:text-lg md:leading-[1.7]"
			>
				Vêtements de qualité supérieure fabriqués avec précision. Designs personnalisés adaptés à vos spécifications. Production en gros fiable pour les institutions et entreprises de toutes tailles.
			</p>

			<div class="hero-reveal mt-10 flex flex-col gap-4 sm:flex-row sm:flex-wrap sm:items-center" style="--hero-d: 240ms">
				<a
					href="/contact"
					class="cta-button-primary group relative inline-flex min-h-[3.25rem] items-center justify-center overflow-hidden rounded-full px-8 py-3.5 text-center text-[13px] font-semibold uppercase tracking-[0.18em] text-background transition-all duration-500"
					style="background: linear-gradient(135deg, #FACC6B 0%, #F59E0B 50%, #D97706 100%); box-shadow: inset 0 1px 0 rgba(255,255,255,0.15), 0 18px 40px rgba(0, 0, 0, 0.50); border: 1px solid rgba(161, 98, 7, 0.7);"
				>
					<span class="relative z-10 transition-transform duration-300 group-hover:scale-[1.02]">Demander un devis</span>
					<span class="cta-button-glow absolute inset-0 rounded-full border-2 border-primary/0 transition-all duration-500 group-hover:border-primary/50 group-hover:shadow-[0_0_30px_rgba(198,161,95,0.4)]"></span>
				</a>
				<a
					href="/products"
					class="cta-button-secondary group relative inline-flex min-h-[3.25rem] items-center justify-center rounded-full border-2 border-[rgba(250,204,107,0.3)] bg-[rgba(0,0,0,0.3)] px-8 py-3.5 text-center text-[13px] font-semibold uppercase tracking-[0.18em] text-[#F9FAFB] transition-all duration-400 hover:bg-[rgba(0,0,0,0.5)] hover:border-[rgba(250,204,107,0.5)]"
				>
					<span class="relative z-10 transition-all duration-300 group-hover:text-[#FACC6B] group-hover:scale-105">Voir nos produits</span>
					<span class="cta-button-glow absolute inset-0 rounded-full border-2 border-primary/0 transition-all duration-400 group-hover:border-primary group-hover:shadow-[0_0_20px_rgba(198,161,95,0.3)]"></span>
				</a>
			</div>

			<div
				class="hero-reveal mt-14 flex flex-row items-center gap-x-6 pt-10 text-sm text-foreground/50 relative"
				style="--hero-d: 320ms"
			>
				<!-- Sewing-inspired dotted line -->
				<div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[rgba(148,163,184,0.25)] to-transparent"></div>
				<span class="font-medium text-foreground/65 whitespace-nowrap">Uniformes sur mesure</span>
				<span class="h-1 w-1 rounded-full bg-primary/50" aria-hidden="true"></span>
				<span class="font-medium text-foreground/65 whitespace-nowrap">Qualité premium</span>
				<span class="h-1 w-1 rounded-full bg-primary/50" aria-hidden="true"></span>
				<span class="font-medium text-foreground/65 whitespace-nowrap">Production en gros</span>
			</div>
		</div>

		<!-- Right Column: 3D Image Gallery -->
		<div
			id="hero-images"
			class="relative w-full lg:w-full"
		>
			<div
				class="hero-3d-container grid gap-4 sm:gap-6 md:min-h-[min(650px,75vh)] md:grid-cols-[1.1fr_0.9fr] md:grid-rows-2 md:gap-6 perspective-1000"
			>
				<!-- Main Card (Larger - Graduation) -->
				<figure
					class="hero-figure-3d group relative col-span-1 overflow-hidden rounded-[1.5rem] border border-[rgba(250,204,107,0.25)] shadow-[0_24px_60px_rgba(0,0,0,0.60)] md:row-span-2 md:min-h-[400px] transform-style-3d transition-all duration-200 ease hover:scale-[1.03] hover:-translate-y-[2px] hover:shadow-[0_32px_80px_rgba(0,0,0,0.70)]"
					data-tilt
				>
					<img
						src={heroImages.graduation}
						alt="Professional graduation gowns manufactured with precision and quality"
						class="hero-img-3d h-full w-full object-cover transition-transform duration-[1.1s] ease-out will-change-transform"
						width="800"
						height="1000"
						loading="eager"
						decoding="async"
						fetchpriority="high"
					/>
					<div
						class="pointer-events-none absolute inset-0 bg-gradient-to-t from-background/50 via-transparent to-transparent md:opacity-100"
					></div>
					<!-- 3D Lighting Overlay -->
					<div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-transparent via-transparent to-primary/10 opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
				</figure>

				<!-- Secondary Card 1 (Smaller - Uniformes) -->
				<figure
					class="hero-figure-3d group relative overflow-hidden rounded-[1.25rem] border border-[rgba(255,255,255,0.06)] shadow-[0_16px_40px_rgba(0,0,0,0.50)] md:min-h-0 transform-style-3d transition-all duration-200 ease hover:scale-[1.03] hover:-translate-y-[2px] hover:shadow-[0_20px_50px_rgba(0,0,0,0.60)]"
					data-tilt
				>
					<img
						src={heroImages.uniformes}
						alt="Custom school uniforms manufactured for educational institutions"
						class="hero-img-3d h-full w-full object-cover transition-transform duration-[1.1s] ease-out will-change-transform"
						width="600"
						height="400"
						loading="eager"
						decoding="async"
					/>
					<div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-background/20 to-transparent"></div>
					<div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-transparent via-transparent to-primary/10 opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
				</figure>

				<!-- Secondary Card 2 (Smaller - Tenues) -->
				<figure
					class="hero-figure-3d group relative overflow-hidden rounded-[1.25rem] border border-[rgba(255,255,255,0.06)] shadow-[0_16px_40px_rgba(0,0,0,0.50)] md:min-h-0 transform-style-3d transition-all duration-200 ease hover:scale-[1.03] hover:-translate-y-[2px] hover:shadow-[0_20px_50px_rgba(0,0,0,0.60)]"
					data-tilt
				>
					<img
						src={heroImages.tenues}
						alt="Workwear uniforms, medical scrubs and lab coats for professional environments"
						class="hero-img-3d h-full w-full object-cover transition-transform duration-[1.1s] ease-out will-change-transform"
						width="600"
						height="400"
						loading="lazy"
						decoding="async"
					/>
					<div class="pointer-events-none absolute inset-0 bg-gradient-to-tl from-background/25 to-transparent"></div>
					<div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-transparent via-transparent to-primary/10 opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
				</figure>
			</div>

			<!-- Decorative Circle -->
			<div
				class="pointer-events-none absolute -right-4 top-1/2 hidden h-48 w-48 -translate-y-1/2 rounded-full border border-primary/10 lg:block xl:-right-8"
				aria-hidden="true"
			></div>
		</div>
	</div>
</section>

<script>
	import gsap from 'gsap';
	import ScrollTrigger from 'gsap/ScrollTrigger';
	import SplitType from 'split-type';
	import { createHeroEntryTimeline, createMouseParallax, prefersReducedMotion, isMobile, animateMarquee, animatePrimaryButtonHover, setupSecondaryButtonHover } from '../lib/animations';

	// Register ScrollTrigger
	gsap.registerPlugin(ScrollTrigger);

	// Vérification des préférences de mouvement réduit
	if (prefersReducedMotion()) {
		// Désactiver toutes les animations si l'utilisateur préfère le mouvement réduit
		document.querySelectorAll('.hero-section *').forEach((el: Element) => {
			(el as HTMLElement).style.animation = 'none';
			(el as HTMLElement).style.transition = 'none';
		});
	} else {
		// Animation d'entrée complète de la Hero section
		const heroTimeline = createHeroEntryTimeline({
			navbar: 'nav',
			subtitle: '#hero-subtitle',
			title: '#hero-title',
			description: '#hero-description',
			buttons: '', // Animation désactivée pour les boutons
			images: '', // Animation désactivée pour les images
			decorative: '.floating-shape-1, .floating-shape-2, .floating-shape-3, .floating-shape-4'
		});

		// Animation des lignes décoratives
		gsap.from('.line-1, .line-2, .line-3, .line-4', {
			scaleY: 0,
			opacity: 0,
			duration: 1,
			ease: 'power3.out',
			stagger: 0.2,
			delay: 0.5
		});

		// Animation du ticker (marquee infini)
		const marqueeContent = document.querySelector('.marquee-content') as HTMLElement;
		if (marqueeContent) {
			animateMarquee('.marquee-content', 30);
		}

		// Effet parallax au mouvement de la souris
		if (!isMobile()) {
			const heroSection = document.getElementById('hero');
			if (heroSection) {
				const cleanupParallax = createMouseParallax(heroSection, [
					{ selector: '.hero-figure-3d:nth-child(1)', xFactor: 1.2, yFactor: 1.2 },
					{ selector: '.hero-figure-3d:nth-child(2)', xFactor: -0.8, yFactor: 0.6 },
					{ selector: '.hero-figure-3d:nth-child(3)', xFactor: 0.5, yFactor: -1 }
				]);

				// Cleanup au démontage
				window.addEventListener('beforeunload', cleanupParallax);
			}
		}

		// Micro-interactions sur les boutons CTA
		animatePrimaryButtonHover('.cta-button-primary');
		setupSecondaryButtonHover('.cta-button-secondary');

		// Parallax au scroll
		if (!isMobile()) {
			const heroSection = document.getElementById('hero');
			if (heroSection) {
				gsap.to('#hero-images', {
					y: -50,
					scrollTrigger: {
						trigger: heroSection,
						start: 'top top',
						end: 'bottom top',
						scrub: 1
					}
				});

				gsap.to('.hero-text-block', {
					y: -30,
					scrollTrigger: {
						trigger: heroSection,
						start: 'top top',
						end: 'bottom top',
						scrub: 1.5
					}
				});
			}
		}

		// 3D Tilt Effect pour les images (optionnel, désactivé si Swiper est utilisé)
		if (!isMobile()) {
			const tiltElements = document.querySelectorAll('[data-tilt]');
			
			tiltElements.forEach((element: Element) => {
				const htmlElement = element as HTMLElement;
				htmlElement.addEventListener('mousemove', (e: Event) => {
					const mouseEvent = e as MouseEvent;
					const rect = htmlElement.getBoundingClientRect();
					const x = mouseEvent.clientX - rect.left;
					const y = mouseEvent.clientY - rect.top;
					
					const centerX = rect.width / 2;
					const centerY = rect.height / 2;
					
					const rotateX = ((y - centerY) / centerY) * -8;
					const rotateY = ((x - centerX) / centerX) * 8;
					
					htmlElement.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02)`;
				});
				
				htmlElement.addEventListener('mouseleave', () => {
					htmlElement.style.transform = 'perspective(1000px) rotateX(0) rotateY(0) scale3d(1, 1, 1)';
				});
			});
		}
	}
</script>

<style>
	/* Animation du gradient sur le mot "Univers" */
	.animated-gradient-text {
		background: linear-gradient(135deg, #FACC6B 0%, #F59E0B 50%, #D97706 100%);
		background-size: 200% auto;
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		animation: gradient-shift 3s linear infinite;
		will-change: background-position;
	}

	@keyframes gradient-shift {
		0% {
			background-position: 0% center;
		}
		100% {
			background-position: 200% center;
		}
	}

	/* Animation pulse pour le bouton WhatsApp */
	.whatsapp-pulse-ring {
		animation: whatsapp-pulse 2s ease-out infinite;
	}

	@keyframes whatsapp-pulse {
		0% {
			transform: scale(1);
			opacity: 0.6;
		}
		50% {
			opacity: 0.3;
		}
		100% {
			transform: scale(1.8);
			opacity: 0;
		}
	}

	/* Optimisation des performances avec will-change */
	.hero-figure-3d {
		will-change: transform;
	}

	.hero-text-block {
		will-change: transform, opacity;
	}

	.cta-button-primary,
	.cta-button-secondary {
		will-change: transform, box-shadow;
	}

	.marquee-content {
		will-change: transform;
	}

	.floating-shape-1,
	.floating-shape-2,
	.floating-shape-3,
	.floating-shape-4 {
		will-change: transform, opacity;
	}

	/* 3D Perspective Container */
	.perspective-1000 {
		perspective: 1000px;
	}

	.transform-style-3d {
