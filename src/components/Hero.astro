---
/**
 * Visuels hero : placez vos fichiers dans public/images/
 * (ajustez les noms ci-dessous si besoin).
 */
const heroImages = {
	graduation: '/images/hero-toges-graduation.jpg',
	uniformes: '/images/hero-uniformes.jpg',
	tenues: '/images/hero-tenues-travail-sport.jpg',
};
---

<section
	id="hero"
	class="relative flex min-h-screen flex-col justify-center overflow-hidden pb-20 pt-28 md:pt-32"
	aria-label="Accueil"
	lang="fr"
>
	<div class="pointer-events-none absolute inset-0 -z-20 bg-background"></div>
	<div
		class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(ellipse_85%_60%_at_100%_0%,rgba(198,161,95,0.14),transparent_55%),radial-gradient(ellipse_70%_50%_at_0%_100%,rgba(91,127,166,0.08),transparent_50%)]"
	>
	</div>
	<div
		class="pointer-events-none absolute inset-0 -z-10 bg-gradient-to-b from-background/80 via-transparent to-background"
	>
	</div>
	<div
		class="pointer-events-none absolute bottom-0 left-1/2 -z-10 h-[45vh] w-[120%] -translate-x-1/2 bg-gradient-to-t from-background to-transparent"
	>
	</div>

	<div
		class="mx-auto grid w-full max-w-7xl items-center gap-12 px-6 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)] lg:gap-16 xl:gap-20"
	>
		<div class="flex flex-col justify-center">
			<p
				class="hero-reveal mb-5 text-[11px] font-semibold uppercase tracking-[0.38em] text-primary md:text-xs"
				style="--hero-d: 0ms"
			>
				Maison de confection · Québec
			</p>

			<h1
				class="hero-reveal font-display text-[clamp(2.5rem,6vw,4.75rem)] font-semibold leading-[1.05] tracking-tight text-foreground md:leading-[1.02]"
				style="--hero-d: 80ms"
			>
				<span class="block text-foreground">Confection</span>
				<span
					class="mt-1 block bg-gradient-to-r from-primary via-primary-light to-primary bg-clip-text text-transparent"
				>
					Univers
				</span>
			</h1>

			<p
				class="hero-reveal mt-8 max-w-xl text-base font-normal leading-relaxed text-foreground/72 md:text-lg md:leading-relaxed"
				style="--hero-d: 160ms"
			>
				Experts en confection de tenues de graduation, uniformes scolaires, tenues de travail, tenues de sport et
				blouses médicales.
			</p>

			<div class="hero-reveal mt-10 flex flex-col gap-4 sm:flex-row sm:flex-wrap sm:items-center" style="--hero-d: 240ms">
				<a
					href="/contact"
					class="group relative inline-flex min-h-[3.25rem] items-center justify-center overflow-hidden rounded-full bg-primary px-8 py-3.5 text-center text-[13px] font-semibold uppercase tracking-[0.18em] text-background shadow-[0_8px_32px_-8px_rgba(198,161,95,0.45)] transition duration-500 hover:shadow-[0_12px_40px_-6px_rgba(198,161,95,0.55)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
				>
					<span class="absolute inset-0 translate-y-full bg-paper transition duration-500 ease-out group-hover:translate-y-0"
					></span>
					<span class="relative transition duration-300 group-hover:text-ink">Commander maintenant</span>
				</a>
				<a
					href="/realisation"
					class="inline-flex min-h-[3.25rem] items-center justify-center rounded-full border border-primary/45 bg-transparent px-8 py-3.5 text-center text-[13px] font-semibold uppercase tracking-[0.18em] text-foreground transition duration-400 hover:border-primary hover:bg-primary/10 hover:text-paper focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
				>
					Voir nos réalisations
				</a>
			</div>

			<div
				class="hero-reveal mt-14 flex flex-wrap items-center gap-x-10 gap-y-3 border-t border-primary/15 pt-10 text-sm text-foreground/50"
				style="--hero-d: 320ms"
			>
				<span class="font-medium text-foreground/65">Sur mesure</span>
				<span class="hidden h-1 w-1 rounded-full bg-primary/50 sm:inline" aria-hidden="true"></span>
				<span class="font-medium text-foreground/65">Qualité professionnelle</span>
				<span class="hidden h-1 w-1 rounded-full bg-primary/50 sm:inline" aria-hidden="true"></span>
				<span class="font-medium text-foreground/65">Délais respectés</span>
			</div>
		</div>

		<div class="relative mx-auto w-full max-w-lg lg:mx-0 lg:max-w-none">
			<div
				class="hero-reveal grid gap-3 sm:gap-4 md:min-h-[min(560px,68vh)] md:grid-cols-[1.12fr_0.88fr] md:grid-rows-2 md:gap-5"
				style="--hero-d: 100ms"
			>
				<figure
					class="hero-figure group relative col-span-1 overflow-hidden rounded-[1.75rem] border border-primary/20 shadow-[0_24px_80px_-24px_rgba(0,0,0,0.55)] md:row-span-2 md:min-h-[280px]"
				>
					<img
						src={heroImages.graduation}
						alt="Toges de graduation confectionnées sur mesure"
						class="hero-img h-full min-h-[240px] w-full object-cover transition duration-[1.1s] ease-out will-change-transform group-hover:scale-[1.03] md:min-h-full"
						width="800"
						height="1000"
						loading="eager"
						decoding="async"
						fetchpriority="high"
					/>
					<div
						class="pointer-events-none absolute inset-0 bg-gradient-to-t from-background/50 via-transparent to-transparent md:opacity-100"
					>
					</div>
				</figure>

				<figure
					class="hero-figure group relative overflow-hidden rounded-2xl border border-primary/15 shadow-lg md:min-h-0"
				>
					<img
						src={heroImages.uniformes}
						alt="Uniformes scolaires"
						class="hero-img h-full min-h-[150px] w-full object-cover transition duration-[1.1s] ease-out will-change-transform group-hover:scale-[1.04] md:min-h-[calc(50%-0.625rem)]"
						width="600"
						height="400"
						loading="eager"
						decoding="async"
					/>
					<div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-background/20 to-transparent"></div>
				</figure>

				<figure
					class="hero-figure group relative overflow-hidden rounded-2xl border border-primary/15 shadow-lg md:min-h-0"
				>
					<img
						src={heroImages.tenues}
						alt="Tenues de travail, sport et blouses médicales"
						class="hero-img h-full min-h-[150px] w-full object-cover transition duration-[1.1s] ease-out will-change-transform group-hover:scale-[1.04] md:min-h-[calc(50%-0.625rem)]"
						width="600"
						height="400"
						loading="lazy"
						decoding="async"
					/>
					<div class="pointer-events-none absolute inset-0 bg-gradient-to-tl from-background/25 to-transparent"></div>
				</figure>
			</div>

			<div
				class="pointer-events-none absolute -right-4 top-1/2 hidden h-48 w-48 -translate-y-1/2 rounded-full border border-primary/10 lg:block xl:-right-8"
				aria-hidden="true"
			>
			</div>
		</div>
	</div>
</section>

<style>
	@keyframes hero-reveal-up {
		from {
			opacity: 0;
			transform: translateY(1.75rem);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes hero-panel-in {
		from {
			opacity: 0;
			transform: translateY(1.35rem) scale(0.99);
		}
		to {
			opacity: 1;
			transform: translateY(0) scale(1);
		}
	}

	@keyframes hero-img-in {
		from {
			opacity: 0;
			transform: scale(1.05);
		}
		to {
			opacity: 1;
			transform: scale(1);
		}
	}

	@media (prefers-reduced-motion: no-preference) {
		.hero-reveal {
			opacity: 0;
			animation: hero-reveal-up 1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
			animation-delay: var(--hero-d, 0ms);
		}

		.hero-reveal.grid {
			animation-name: hero-panel-in;
			animation-duration: 1.1s;
		}

		.hero-figure .hero-img {
			animation: hero-img-in 1.25s cubic-bezier(0.22, 1, 0.36, 1) both;
		}

		.hero-figure:nth-child(1) .hero-img {
			animation-delay: 0.18s;
		}
		.hero-figure:nth-child(2) .hero-img {
			animation-delay: 0.32s;
		}
		.hero-figure:nth-child(3) .hero-img {
			animation-delay: 0.42s;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.hero-reveal {
			opacity: 1;
			animation: none;
		}
		.hero-figure .hero-img {
			animation: none;
			opacity: 1;
		}
	}
</style>
