---
/**
 * Visuels hero : placez vos fichiers dans public/images/
 * (ajustez les noms ci-dessous si besoin).
 */
const heroImages = {
	graduation: '/images/hero-toges-graduation.jpg',
	uniformes: '/images/hero-uniformes.jpg',
	tenues: '/images/hero-tenues-travail-sport.jpg',
};

const galleryItems = [
	{ image: '/images/gallery1.jpg', label: 'Toges de graduation' },
	{ image: '/images/gallery2.jpg', label: 'Uniformes scolaires' },
	{ image: '/images/gallery3.jpg', label: 'Tenues d\'entreprise' },
];

---

<section
	id="hero"
	class="hero-section relative flex min-h-screen flex-col justify-center overflow-hidden pb-0 pt-36 md:pt-40 border-0 outline-none mb-[-1px]"
	aria-label="Accueil"
	lang="fr"
	style="border: none !important; outline: none !important; box-shadow: none !important; background: linear-gradient(135deg, #050816 0%, #0b1024 60%, #020617 100%);"
>
	<!-- Grain Texture Overlay -->
	<div class="pointer-events-none absolute inset-0 -z-10 opacity-[0.05]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.65%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E');"></div>
	
	<!-- Premium Golden Glow Behind Images -->
	<div class="pointer-events-none absolute right-[5%] top-[30%] -z-10 w-[600px] h-[500px] rounded-full" style="background: radial-gradient(ellipse, rgba(250, 204, 107, 0.2) 0%, transparent 70%); filter: blur(80px);"></div>
	
	<!-- Mesh Gradients & Glow Effects -->
	<div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
		<!-- Primary Glow -->
		<div class="absolute left-[5%] top-[10%] w-[500px] h-[500px] rounded-full bg-primary/20 blur-[120px] animate-pulse"></div>
		<!-- Secondary Glow -->
		<div class="absolute right-[10%] bottom-[20%] w-[400px] h-[400px] rounded-full bg-primary-light/15 blur-[100px] animate-pulse" style="animation-delay: 1s;"></div>
		<!-- Accent Glow -->
		<div class="absolute left-[50%] top-[50%] w-[300px] h-[300px] rounded-full bg-primary/10 blur-[80px] animate-pulse" style="animation-delay: 2s;"></div>
		<!-- Mesh Gradient Overlay -->
		<div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-primary-light/5"></div>
	</div>

	<!-- Animated Floating Shapes -->
	<div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
		<div class="floating-shape-1 absolute left-[10%] top-[20%] w-20 h-20 border border-primary/30 rounded-full opacity-20"></div>
		<div class="floating-shape-2 absolute right-[15%] top-[40%] w-16 h-16 border border-primary-light/30 rounded-lg opacity-20"></div>
		<div class="floating-shape-3 absolute left-[20%] bottom-[30%] w-24 h-24 border border-primary/30 rounded-full opacity-20"></div>
		<div class="floating-shape-4 absolute right-[25%] bottom-[20%] w-12 h-12 border border-primary-light/30 rounded-lg opacity-20"></div>
	</div>

	<!-- Line Animations -->
	<div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
		<div class="line-1 absolute left-[5%] top-[15%] w-[1px] h-[200px] bg-gradient-to-b from-transparent via-primary/30 to-transparent"></div>
		<div class="line-2 absolute right-[10%] top-[25%] w-[1px] h-[150px] bg-gradient-to-b from-transparent via-primary-light/30 to-transparent"></div>
		<div class="line-3 absolute left-[15%] bottom-[20%] w-[1px] h-[180px] bg-gradient-to-b from-transparent via-primary/30 to-transparent"></div>
		<div class="line-4 absolute right-[20%] bottom-[15%] w-[1px] h-[120px] bg-gradient-to-b from-transparent via-primary-light/30 to-transparent"></div>
	</div>

	<!-- Marquee Text Animation -->
	<div class="absolute bottom-0 left-0 right-0 overflow-hidden pointer-events-none">
		<div class="marquee-container flex whitespace-nowrap">
			<div class="marquee-content flex items-center gap-8 text-primary/40 text-sm uppercase tracking-widest">
				<span>Confection de Toges</span>
				<span class="w-2 h-2 rounded-full bg-primary/40"></span>
				<span>Uniformes Scolaires</span>
				<span class="w-2 h-2 rounded-full bg-primary/40"></span>
				<span>Tenues de Travail</span>
				<span class="w-2 h-2 rounded-full bg-primary/40"></span>
				<span>Équipements Sportifs</span>
				<span class="w-2 h-2 rounded-full bg-primary/40"></span>
				<span>Blouses Médicales</span>
				<span class="w-2 h-2 rounded-full bg-primary/40"></span>
				<span>Confection de Toges</span>
				<span class="w-2 h-2 rounded-full bg-primary/40"></span>
				<span>Uniformes Scolaires</span>
				<span class="w-2 h-2 rounded-full bg-primary/40"></span>
				<span>Tenues de Travail</span>
				<span class="w-2 h-2 rounded-full bg-primary/40"></span>
				<span>Équipements Sportifs</span>
				<span class="w-2 h-2 rounded-full bg-primary/40"></span>
				<span>Blouses Médicales</span>
				<span class="w-2 h-2 rounded-full bg-primary/40"></span>
			</div>
		</div>
	</div>
	
	<!-- Main Content -->
	<div
		class="hero-content mx-auto grid w-full max-w-7xl items-center gap-12 px-6 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)] lg:gap-16 xl:gap-20 relative"
	>
		<!-- Sewing-inspired vertical divider line -->
		<div class="hidden lg:block absolute left-[50%] top-[20%] bottom-[20%] w-px bg-gradient-to-b from-transparent via-[rgba(148,163,184,0.25)] to-transparent -translate-x-1/2"></div>
		
		<!-- Sewing pattern markers (subtle circles) -->
		<div class="hidden lg:block absolute left-[45%] top-[25%] w-2 h-2 rounded-full border border-[rgba(148,163,184,0.15)] -translate-x-1/2" aria-hidden="true"></div>
		<div class="hidden lg:block absolute left-[45%] top-[50%] w-2 h-2 rounded-full border border-[rgba(148,163,184,0.15)] -translate-x-1/2" aria-hidden="true"></div>
		<div class="hidden lg:block absolute left-[45%] top-[75%] w-2 h-2 rounded-full border border-[rgba(148,163,184,0.15)] -translate-x-1/2" aria-hidden="true"></div>

		<!-- Left Column: Text Content -->
		<div class="hero-text-block flex flex-col justify-center">
			<p
				id="hero-subtitle"
				class="mb-5 text-[11px] font-semibold uppercase tracking-[0.2em] text-[rgba(250,204,107,0.7)] md:text-xs"
			>
				CONFECTION DE VÊTEMENTS PROFESSIONNELS - SÉNÉGAL
			</p>

			<h1
				id="hero-title"
				class="font-display text-[clamp(2.5rem,6vw,4.75rem)] font-semibold leading-[1.05] tracking-tight md:leading-[1.02]"
			>
				<span class="block text-[#F9FAFB]">Confection</span>
				<span
					class="mt-1 block font-bold"
					style="background: linear-gradient(135deg, #FACC6B 0%, #F59E0B 50%, #D97706 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
				>
					Univers
				</span>
			</h1>

			<p
				id="hero-description"
				class="mt-8 max-w-xl text-base font-normal leading-[1.6] text-foreground/72 md:text-lg md:leading-[1.7]"
			>
				Vêtements de qualité supérieure fabriqués avec précision. Designs personnalisés adaptés à vos spécifications. Production en gros fiable pour les institutions et entreprises de toutes tailles.
			</p>

			<div class="hero-reveal mt-10 flex flex-col gap-4 sm:flex-row sm:flex-wrap sm:items-center" style="--hero-d: 240ms">
				<a
					href="/contact"
					class="cta-button-primary group relative inline-flex min-h-[3.25rem] items-center justify-center overflow-hidden rounded-full px-8 py-3.5 text-center text-[13px] font-semibold uppercase tracking-[0.18em] text-background transition-all duration-500"
					style="background: linear-gradient(135deg, #FACC6B 0%, #F59E0B 50%, #D97706 100%); box-shadow: inset 0 1px 0 rgba(255,255,255,0.15), 0 18px 40px rgba(0, 0, 0, 0.50); border: 1px solid rgba(161, 98, 7, 0.7);"
				>
					<span class="relative z-10 transition-transform duration-300 group-hover:scale-[1.02]">Demander un devis</span>
					<span class="cta-button-glow absolute inset-0 rounded-full border-2 border-primary/0 transition-all duration-500 group-hover:border-primary/50 group-hover:shadow-[0_0_30px_rgba(198,161,95,0.4)]"></span>
				</a>
				<a
					href="/products"
					class="cta-button-secondary group relative inline-flex min-h-[3.25rem] items-center justify-center rounded-full border-2 border-[rgba(250,204,107,0.3)] bg-[rgba(0,0,0,0.3)] px-8 py-3.5 text-center text-[13px] font-semibold uppercase tracking-[0.18em] text-[#F9FAFB] transition-all duration-400 hover:bg-[rgba(0,0,0,0.5)] hover:border-[rgba(250,204,107,0.5)]"
				>
					<span class="relative z-10 transition-all duration-300 group-hover:text-[#FACC6B] group-hover:scale-105">Voir nos produits</span>
					<span class="cta-button-glow absolute inset-0 rounded-full border-2 border-primary/0 transition-all duration-400 group-hover:border-primary group-hover:shadow-[0_0_20px_rgba(198,161,95,0.3)]"></span>
				</a>
			</div>

			<div
				class="hero-reveal mt-14 flex flex-wrap items-center gap-x-10 gap-y-3 pt-10 text-sm text-foreground/50 relative"
				style="--hero-d: 320ms"
			>
				<!-- Sewing-inspired dotted line -->
				<div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[rgba(148,163,184,0.25)] to-transparent"></div>
				<span class="font-medium text-foreground/65">Uniformes sur mesure</span>
				<span class="hidden h-1 w-1 rounded-full bg-primary/50 sm:inline" aria-hidden="true"></span>
				<span class="font-medium text-foreground/65">Qualité premium</span>
				<span class="hidden h-1 w-1 rounded-full bg-primary/50 sm:inline" aria-hidden="true"></span>
				<span class="font-medium text-foreground/65">Production en gros</span>
			</div>
		</div>

		<!-- Right Column: 3D Image Gallery -->
		<div
			id="hero-images"
			class="relative mx-auto w-full max-w-lg lg:mx-0 lg:max-w-none"
		>
			<div
				class="hero-3d-container grid gap-3 sm:gap-4 md:min-h-[min(560px,68vh)] md:grid-cols-[1.12fr_0.88fr] md:grid-rows-2 md:gap-5 perspective-1000"
			>
				<!-- Main Card (Larger - Graduation) -->
				<figure
					class="hero-figure-3d group relative col-span-1 overflow-hidden rounded-[1.5rem] border border-[rgba(250,204,107,0.25)] shadow-[0_24px_60px_rgba(0,0,0,0.60)] md:row-span-2 md:min-h-[320px] transform-style-3d transition-all duration-200 ease hover:scale-[1.03] hover:-translate-y-[2px] hover:shadow-[0_32px_80px_rgba(0,0,0,0.70)]"
					data-tilt
				>
					<img
						src={heroImages.graduation}
						alt="Professional graduation gowns manufactured with precision and quality"
						class="hero-img-3d h-full min-h-[240px] w-full object-cover transition-transform duration-[1.1s] ease-out will-change-transform md:min-h-full"
						width="800"
						height="1000"
						loading="eager"
						decoding="async"
						fetchpriority="high"
					/>
					<div
						class="pointer-events-none absolute inset-0 bg-gradient-to-t from-background/50 via-transparent to-transparent md:opacity-100"
					></div>
					<!-- 3D Lighting Overlay -->
					<div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-transparent via-transparent to-primary/10 opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
				</figure>

				<!-- Secondary Card 1 (Smaller - Uniformes) -->
				<figure
					class="hero-figure-3d group relative overflow-hidden rounded-[1.25rem] border border-[rgba(255,255,255,0.06)] shadow-[0_16px_40px_rgba(0,0,0,0.50)] md:min-h-0 transform-style-3d transition-all duration-200 ease hover:scale-[1.03] hover:-translate-y-[2px] hover:shadow-[0_20px_50px_rgba(0,0,0,0.60)]"
					data-tilt
				>
					<img
						src={heroImages.uniformes}
						alt="Custom school uniforms manufactured for educational institutions"
						class="hero-img-3d h-full min-h-[140px] w-full object-cover transition-transform duration-[1.1s] ease-out will-change-transform md:min-h-[calc(50%-0.625rem)]"
						width="600"
						height="400"
						loading="eager"
						decoding="async"
					/>
					<div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-background/20 to-transparent"></div>
					<div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-transparent via-transparent to-primary/10 opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
				</figure>

				<!-- Secondary Card 2 (Smaller - Tenues) -->
				<figure
					class="hero-figure-3d group relative overflow-hidden rounded-[1.25rem] border border-[rgba(255,255,255,0.06)] shadow-[0_16px_40px_rgba(0,0,0,0.50)] md:min-h-0 transform-style-3d transition-all duration-200 ease hover:scale-[1.03] hover:-translate-y-[2px] hover:shadow-[0_20px_50px_rgba(0,0,0,0.60)]"
					data-tilt
				>
					<img
						src={heroImages.tenues}
						alt="Workwear uniforms, medical scrubs and lab coats for professional environments"
						class="hero-img-3d h-full min-h-[140px] w-full object-cover transition-transform duration-[1.1s] ease-out will-change-transform md:min-h-[calc(50%-0.625rem)]"
						width="600"
						height="400"
						loading="lazy"
						decoding="async"
					/>
					<div class="pointer-events-none absolute inset-0 bg-gradient-to-tl from-background/25 to-transparent"></div>
					<div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-transparent via-transparent to-primary/10 opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
				</figure>
			</div>

			<!-- Decorative Circle -->
			<div
				class="pointer-events-none absolute -right-4 top-1/2 hidden h-48 w-48 -translate-y-1/2 rounded-full border border-primary/10 lg:block xl:-right-8"
				aria-hidden="true"
			></div>
		</div>
	</div>
</section>

<script>
	import gsap from 'gsap';
	import ScrollTrigger from 'gsap/ScrollTrigger';
	import SplitType from 'split-type';

	// Register ScrollTrigger
	gsap.registerPlugin(ScrollTrigger);

	// Mobile detection for mouse tracking
	const isMobile = () => {
		return /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent) || 
		       ('ontouchstart' in window) || 
		       (navigator.maxTouchPoints > 0);
	};

	// Complex Hero Animations with GSAP - Premium Cinematic Style
	if (!isMobile()) {
		// Cinematic entry animations
		const heroTimeline = gsap.timeline();

		// Text block fade-in with translateY and overshoot
		heroTimeline.from('.hero-text-block', {
			opacity: 0,
			y: 20,
			duration: 0.6,
			ease: 'back.out(1.2)'
		});

		// Subtitle fade-in-up with stagger
		heroTimeline.from('#hero-subtitle', {
			opacity: 0,
			y: 15,
			duration: 0.5,
			ease: 'power2.out'
		}, '-=0.3');

		// Title fade-in-up with stagger and overshoot
		const heroTitle = document.querySelector('#hero-title');
		if (heroTitle) {
			const splitTitle = new SplitType(heroTitle, { types: 'words' });
			
			heroTimeline.from(splitTitle.words, {
				opacity: 0,
				y: 25,
				duration: 0.7,
				ease: 'back.out(1.1)',
				stagger: 0.06
			}, '-=0.3');
		}

		// Description fade-in-up
		heroTimeline.from('#hero-description', {
			opacity: 0,
			y: 15,
			duration: 0.5,
			ease: 'power2.out'
		}, '-=0.4');

		// Buttons scale-in with glow
		heroTimeline.from('.hero-reveal', {
			opacity: 0,
			scale: 0.95,
			y: 10,
			duration: 0.5,
			ease: 'back.out(1.15)',
			stagger: 0.08
		}, '-=0.3');

		// Add glow animation to primary button
		heroTimeline.to('.hero-reveal:first-child', {
			boxShadow: 'inset 0 1px 0 rgba(255,255,255,0.15), 0 18px 40px rgba(0, 0, 0, 0.50)',
			duration: 0.6,
			ease: 'power2.out'
		}, '-=0.4');

		// Hero images slide-in from right with rotation
		heroTimeline.from('#hero-images', {
			opacity: 0,
			x: 40,
			rotation: 3,
			duration: 0.7,
			ease: 'power2.out'
		}, '-=0.5');

		// Individual photo cards stagger
		const photoCards = document.querySelectorAll('.hero-photo-card');
		if (photoCards.length > 0) {
			heroTimeline.from(photoCards, {
				opacity: 0,
				y: 20,
				rotation: (i) => i % 2 === 0 ? 2 : -2,
				duration: 0.5,
				ease: 'power2.out',
				stagger: 0.1
			}, '-=0.5');
		}

		// Animate floating shapes with elastic effect
		gsap.from('.floating-shape-1', {
			opacity: 0,
			scale: 0,
			duration: 1.5,
			ease: 'elastic.out(1, 0.5)',
			delay: 0.3
		});

		gsap.from('.floating-shape-2', {
			opacity: 0,
			scale: 0,
			duration: 1.5,
			ease: 'elastic.out(1, 0.5)',
			delay: 0.5
		});

		gsap.from('.floating-shape-3', {
			opacity: 0,
			scale: 0,
			duration: 1.5,
			ease: 'elastic.out(1, 0.5)',
			delay: 0.7
		});

		gsap.from('.floating-shape-4', {
			opacity: 0,
			scale: 0,
			duration: 1.5,
			ease: 'elastic.out(1, 0.5)',
			delay: 0.9
		});

		// Animate lines with stagger
		gsap.from('.line-1, .line-2, .line-3, .line-4', {
			scaleY: 0,
			opacity: 0,
			duration: 1,
			ease: 'power3.out',
			stagger: 0.2,
			delay: 0.3
		});

		// Animate marquee
		gsap.from('.marquee-content', {
			x: '100%',
			duration: 2,
			ease: 'power2.out',
			delay: 1.5
		});

		// Parallax effect on mouse movement for 3D depth
		const heroSection = document.getElementById('hero');
		if (heroSection) {
			heroSection.addEventListener('mousemove', (e) => {
				const mouseX = (e.clientX / window.innerWidth) - 0.5;
				const mouseY = (e.clientY / window.innerHeight) - 0.5;

				gsap.to('.floating-shape-1', {
					x: mouseX * 30,
					y: mouseY * 30,
					duration: 1,
					ease: 'power2.out'
				});

				gsap.to('.floating-shape-2', {
					x: mouseX * -20,
					y: mouseY * -20,
					duration: 1,
					ease: 'power2.out'
				});

				gsap.to('.floating-shape-3', {
					x: mouseX * 25,
					y: mouseY * -25,
					duration: 1,
					ease: 'power2.out'
				});

				gsap.to('.floating-shape-4', {
					x: mouseX * -30,
					y: mouseY * 30,
					duration: 1,
					ease: 'power2.out'
				});

				gsap.to('#hero-images', {
					x: mouseX * -15,
					y: mouseY * -15,
					duration: 1,
					ease: 'power2.out'
				});
			});

			// Scroll-based parallax effects
			gsap.to('#hero-images', {
				y: -50,
				scrollTrigger: {
					trigger: heroSection,
					start: 'top top',
					end: 'bottom top',
					scrub: 1
				}
			});

			// Parallax for golden glow
			const goldenGlow = document.querySelector('.golden-glow');
			if (goldenGlow) {
				gsap.to(goldenGlow, {
					opacity: 0.15,
					scale: 1.1,
					scrollTrigger: {
						trigger: heroSection,
						start: 'top top',
						end: 'bottom top',
						scrub: 1
					}
				});
			}

			// Subtle text parallax
			gsap.to('.hero-text-block', {
				y: -30,
				scrollTrigger: {
					trigger: heroSection,
					start: 'top top',
					end: 'bottom top',
					scrub: 1.5
				}
			});
		}
	}

	// GSAP Animations for Hero with staggered timing - DISABLED for now
	// const heroTimeline = gsap.timeline();

	// heroTimeline
	// 	.to('#hero-subtitle', {
	// 		opacity: 1,
	// 		y: 0,
	// 		duration: 0.8,
	// 		ease: 'power3.out'
	// 	})
	// 	.to('#hero-images', {
	// 		opacity: 1,
	// 		y: 0,
	// 		duration: 0.8,
	// 		ease: 'power3.out'
	// 	}, '-=0.4');

	// Parallax effect on scroll for hero images
	if (!isMobile()) {
		window.addEventListener('scroll', () => {
			const scrolled = window.pageYOffset;
			const heroImages = document.getElementById('hero-images');
			if (heroImages) {
				heroImages.style.transform = `translateY(${scrolled * 0.1}px)`;
			}
		});
	}

	// 3D Tilt Effect for Images
	if (!isMobile()) {
		const tiltElements = document.querySelectorAll('[data-tilt]');
		
		tiltElements.forEach(element => {
			element.addEventListener('mousemove', (e) => {
				const rect = element.getBoundingClientRect();
				const x = e.clientX - rect.left;
				const y = e.clientY - rect.top;
				
				const centerX = rect.width / 2;
				const centerY = rect.height / 2;
				
				const rotateX = ((y - centerY) / centerY) * -8; // Max 8deg rotation
				const rotateY = ((x - centerX) / centerX) * 8;
				
				element.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02)`;
			});
			
			element.addEventListener('mouseleave', () => {
				element.style.transform = 'perspective(1000px) rotateX(0) rotateY(0) scale3d(1, 1, 1)';
			});
		});
	}

	// Mouse Parallax for Floating Shapes
	if (!isMobile()) {
		const shapes = document.querySelectorAll('.shape');
		const heroSection = document.querySelector('.hero-section');
		
		heroSection.addEventListener('mousemove', (e) => {
			const x = (e.clientX / window.innerWidth - 0.5) * 2;
			const y = (e.clientY / window.innerHeight - 0.5) * 2;
			
			shapes.forEach((shape, index) => {
				const speed = (index + 1) * 15;
				const translateX = x * speed;
				const translateY = y * speed;
				
				shape.style.transform = `translate(${translateX}px, ${translateY}px)`;
			});
		});
	}
</script>

