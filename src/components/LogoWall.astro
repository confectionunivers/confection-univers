---
interface Props {
	logos: Array<{ name: string; src: string; alt: string }>;
}

const { logos } = Astro.props;
---

<div class="grid grid-cols-2 gap-8 md:grid-cols-3 lg:grid-cols-6">
	{logos.map((logo) => (
		<div class="flex items-center justify-center rounded-xl border border-primary/10 bg-surface/20 p-6 transition-all duration-300 hover:border-primary/30 hover:bg-surface/30">
			<img
				src={logo.src}
				alt={logo.alt}
				class="h-12 w-auto object-contain opacity-60 transition-all duration-300 hover:opacity-100 grayscale hover:grayscale-0"
				loading="lazy"
				decoding="async"
			/>
		</div>
	))}
</div>
