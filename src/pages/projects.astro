---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const projects = [
	{
		title: 'Université Cheikh Anta Diop',
		category: 'Toges de graduation',
		description: 'Confection de 500 toges de graduation pour la cérémonie de remise des diplômes 2025, avec tissus premium et finitions dorées.',
		image: '/images/toge-graduation.jpg',
		year: '2025',
	},
	{
		title: 'Hôpital Principal de Dakar',
		category: 'Tenues médicales',
		description: 'Fourniture de 200 blouses médicales et tuniques pour le personnel soignant, avec poches fonctionnelles et tissus antibactériens.',
		image: '/images/blouse-medicale.jpg',
		year: '2024',
	},
	{
		title: 'Lycée Saint-Michel',
		category: 'Uniformes scolaires',
		description: 'Programme complet d\'uniformes pour 800 élèves, incluant chemises, pantalons et jupes aux couleurs de l\'établissement.',
		image: '/images/uniforme-scolaire.jpg',
		year: '2024',
	},
	{
		title: 'Sonatel Sénégal',
		category: 'Tenues d\'entreprise',
		description: 'Tenues de travail professionnelles pour 350 employés, intégrant le logo et les couleurs de marque de l\'entreprise.',
		image: '/images/tenue-travail.jpg',
		year: '2024',
	},
	{
		title: 'Festival de Jazz de Saint-Louis',
		category: 'Costumes africains',
		description: 'Création de costumes traditionnels en bazin pour les artistes et organisateurs du festival, alliant modernité et tradition.',
		image: '/images/costume-africain.jpg',
		year: '2023',
	},
	{
		title: 'ASC Jaraaf',
		category: 'Tenues de sport',
		description: 'Maillots d\'équipe et équipements pour 150 joueurs du club de football, avec tissus respirants et designs personnalisés.',
		image: '/images/tenue-sport.jpg',
		year: '2023',
	},
];
---

<Layout title="Projets | Confection Univers">
	<main class="relative">
		<Navbar />
		
		<!-- Hero Section -->
		<section class="relative flex min-h-[60vh] flex-col justify-center overflow-hidden pb-20 pt-32 md:pt-40">
			<div class="pointer-events-none absolute inset-0 -z-20 bg-background"></div>
			<div class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(ellipse_85%_60%_at_100%_0%,rgba(198,161,95,0.14),transparent_55%),radial-gradient(ellipse_70%_50%_at_0%_100%,rgba(0,0,42,0.08),transparent_50%)]"></div>
			
			<div class="mx-auto max-w-7xl px-6">
				<p class="mb-5 text-[11px] font-semibold uppercase tracking-[0.38em] text-primary md:text-xs">
					Nos réalisations
				</p>
				<h1 class="font-display text-[clamp(2.5rem,6vw,4.75rem)] font-semibold leading-[1.05] tracking-tight text-foreground md:leading-[1.02]">
					<span class="block text-foreground">Nos</span>
					<span class="mt-1 block bg-gradient-to-r from-primary via-primary-light to-primary bg-clip-text text-transparent">
						Projets
					</span>
				</h1>
				<p class="mt-8 max-w-2xl text-base font-normal leading-relaxed text-foreground/72 md:text-lg md:leading-relaxed">
					Découvrez nos collaborations avec les plus grandes institutions et entreprises du Sénégal. Chaque projet témoigne de notre engagement envers la qualité et l'excellence.
				</p>
			</div>
		</section>

		<!-- Projects Grid Section -->
		<section class="relative z-10 -mt-10 scroll-mt-24 rounded-[3rem] border border-ink/5 bg-paper py-24 text-ink shadow-[0_24px_80px_-28px_rgba(5,10,20,0.14)] md:rounded-[4rem] md:py-32">
			<div class="mx-auto max-w-7xl px-6">
				<div class="mx-auto mb-16 max-w-3xl text-center md:mb-20">
					<p class="mb-4 text-[11px] font-semibold uppercase tracking-[0.35em] text-primary md:text-xs">Portfolio</p>
					<h2 class="font-display text-4xl font-semibold leading-tight tracking-tight text-ink md:text-5xl lg:text-6xl">
						Réalisations remarquables
					</h2>
					<p class="mt-6 text-base leading-relaxed text-ink/65 md:text-lg">
						Plus de 500 projets réalisés avec succès pour des clients prestigieux à travers le Sénégal.
					</p>
				</div>

				<div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
					{
						projects.map((project, i) => (
							<article class="group relative overflow-hidden rounded-3xl border border-ink/10 bg-paper shadow-[0_8px_32px_-12px_rgba(5,10,20,0.12)] transition duration-500 ease-out will-change-transform hover:-translate-y-2 hover:border-primary/30 hover:shadow-[0_20px_60px_-16px_rgba(5,10,20,0.2)]">
								<div class="relative aspect-[4/3] overflow-hidden bg-surface/40">
									<img
										src={project.image}
										alt={project.title}
										class="h-full w-full object-cover transition duration-700 ease-out group-hover:scale-105"
										width="800"
										height="600"
										loading={i < 3 ? 'eager' : 'lazy'}
										decoding="async"
									/>
									<div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-ink/70 via-ink/20 to-transparent opacity-90"></div>
									<div class="absolute top-6 left-6">
										<span class="inline-flex rounded-full bg-primary/90 px-4 py-2 text-[11px] font-semibold uppercase tracking-widest text-paper backdrop-blur-sm">
											{project.year}
										</span>
									</div>
									<div class="absolute bottom-6 left-6 right-6">
										<span class="inline-flex items-center gap-2 rounded-full bg-background/85 px-4 py-2 text-[11px] font-semibold uppercase tracking-widest text-primary backdrop-blur-sm">
											{project.category}
										</span>
									</div>
								</div>

								<div class="p-8">
									<h3 class="font-display text-2xl font-semibold leading-tight tracking-tight text-ink transition duration-300 group-hover:text-primary">
										{project.title}
									</h3>
									<p class="mt-4 text-base leading-relaxed text-ink/65">
										{project.description}
									</p>
								</div>
							</article>
						))
					}
				</div>

				<div class="mt-16 flex flex-col items-center justify-center gap-4 border-t border-primary/10 pt-12 text-center md:mt-20 md:flex-row md:gap-8">
					<p class="max-w-md text-sm text-ink/55 md:text-base">Vous avez un projet similaire ? Discutons de vos besoins et créons ensemble la solution idéale.</p>
					<a
						href="/contact"
						class="inline-flex shrink-0 items-center justify-center rounded-full border border-primary/40 bg-ink px-8 py-3.5 text-[12px] font-semibold uppercase tracking-[0.18em] text-paper transition duration-400 hover:bg-primary hover:text-background"
					>
						Démarrer un projet
					</a>
				</div>
			</div>
		</section>

		<!-- Stats Section -->
		<section class="relative z-10 -mt-10 rounded-[4rem] bg-background py-32 text-foreground">
			<div class="mx-auto max-w-7xl px-6">
				<div class="grid gap-16 md:grid-cols-4">
					<div class="space-y-4 text-center">
						<div class="font-display text-6xl font-bold tracking-tighter text-primary md:text-7xl">500+</div>
						<p class="text-sm font-semibold uppercase tracking-widest text-foreground/60">Projets réalisés</p>
					</div>

					<div class="space-y-4 text-center">
						<div class="font-display text-6xl font-bold tracking-tighter text-primary md:text-7xl">250K+</div>
						<p class="text-sm font-semibold uppercase tracking-widest text-foreground/60">Vêtements produits</p>
					</div>

					<div class="space-y-4 text-center">
						<div class="font-display text-6xl font-bold tracking-tighter text-primary md:text-7xl">98%</div>
						<p class="text-sm font-semibold uppercase tracking-widest text-foreground/60">Satisfaction client</p>
					</div>

					<div class="space-y-4 text-center">
						<div class="font-display text-6xl font-bold tracking-tighter text-primary md:text-7xl">20+</div>
						<p class="text-sm font-semibold uppercase tracking-widest text-foreground/60">Années d'expérience</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Testimonials Section -->
		<section class="relative z-10 -mt-10 rounded-[4rem] bg-paper py-32 text-ink shadow-[0_-20px_80px_-20px_rgba(5,10,20,0.15)]">
			<div class="mx-auto max-w-7xl px-6">
				<div class="mx-auto mb-16 max-w-3xl text-center md:mb-20">
					<p class="mb-4 text-[11px] font-semibold uppercase tracking-[0.35em] text-primary md:text-xs">Témoignages</p>
					<h2 class="font-display text-4xl font-semibold leading-tight tracking-tight text-ink md:text-5xl lg:text-6xl">
						Ce que disent nos clients
					</h2>
				</div>

				<div class="grid gap-12 md:grid-cols-2">
					<div class="space-y-6 rounded-3xl border border-ink/10 bg-surface/10 p-8">
						<div class="flex gap-1 text-primary">
							<span>★</span>
							<span>★</span>
							<span>★</span>
							<span>★</span>
							<span>★</span>
						</div>
						<p class="text-lg leading-relaxed text-ink/80">
							"Confection Univers a livré des toges de graduation exceptionnelles pour notre université. La qualité des tissus et la finition impeccable ont impressionné tous nos diplômés."
						</p>
						<div class="flex items-center gap-4">
							<div class="h-12 w-12 rounded-full bg-primary/20"></div>
							<div>
								<div class="font-bold text-ink">Dr. Amadou Diallo</div>
								<div class="text-sm text-ink/60">Doyen, Université Cheikh Anta Diop</div>
							</div>
						</div>
					</div>

					<div class="space-y-6 rounded-3xl border border-ink/10 bg-surface/10 p-8">
						<div class="flex gap-1 text-primary">
							<span>★</span>
							<span>★</span>
							<span>★</span>
							<span>★</span>
							<span>★</span>
						</div>
						<p class="text-lg leading-relaxed text-ink/80">
							"Les uniformes scolaires fournis sont de qualité supérieure et résistent parfaitement à l'usage quotidien. Un partenaire fiable pour notre établissement."
						</p>
						<div class="flex items-center gap-4">
							<div class="h-12 w-12 rounded-full bg-primary/20"></div>
							<div>
								<div class="font-bold text-ink">Mme Fatou Ndiaye</div>
								<div class="text-sm text-ink/60">Directrice, Lycée Saint-Michel</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<Footer />
	</main>
</Layout>
